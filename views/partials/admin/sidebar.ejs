<style>
  .admin-sidebar {
    position: fixed;
    top: 70px;
    left: 0;
    height: calc(100vh - 70px);
    width: 260px;
    background: #ffffff;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.05);
    overflow-y: auto;
    z-index: 1020;
    transition: all 0.3s ease;
  }

  .sidebar-nav {
    padding: 1.5rem 0;
  }

  .sidebar-nav .nav-link {
    color: #495057;
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
    border-left: 3px solid transparent;
    text-decoration: none;
  }

  .sidebar-nav .nav-link:hover {
    background-color: #f8f9fa;
    color: #667eea;
    border-left-color: #667eea;
    padding-left: 1.75rem;
  }

  .sidebar-nav .nav-link.active {
    background: linear-gradient(90deg, rgba(102, 126, 234, 0.1) 0%, transparent 100%);
    color: #667eea;
    font-weight: 600;
    border-left-color: #667eea;
  }

  .sidebar-nav .nav-link i {
    font-size: 1.1rem;
    width: 24px;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .admin-sidebar {
      transform: translateX(-100%);
      width: 240px;
    }

    .admin-sidebar.show {
      transform: translateX(0);
    }
  }
</style>
<script>
  // Set active menu item based on current route
  (function() {
    const currentPath = window.location.pathname;
    
    // Find all nav links
    const navLinks = document.querySelectorAll('.sidebar-nav .nav-link');
    
    navLinks.forEach(link => {
      // Remove active class from all links
      link.classList.remove('active');
      
      // Get the href from the link
      const linkHref = link.getAttribute('href') || '';
      
      // Skip links with # or empty href
      if (!linkHref || linkHref === '#') return;
      
      // Check if current path matches or starts with link href
      // This handles sub-routes like /admin/products/add -> highlights Products
      if (currentPath === linkHref || currentPath.startsWith(linkHref + '/')) {
        link.classList.add('active');
      }
    });
    
    // Special case for dashboard (root /admin path)
    if (currentPath === '/admin' || currentPath === '/admin/') {
      const dashboardLink = document.querySelector('[data-route="dashboard"]');
      if (dashboardLink) {
        // Remove active from all first
        navLinks.forEach(link => link.classList.remove('active'));
        dashboardLink.classList.add('active');
      }
    }
  })();
</script>

