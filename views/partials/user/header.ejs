<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>MehzMen</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Nanum+Myeongjo&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/user/userHeader.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg custom-navbar fixed-top">
        <div class="container-fluid">

            <!-- Logo -->
            <a class="navbar-brand logo-text" href="/">MehzMen</a>

            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">

                <ul class="navbar-nav align-items-lg-center">

                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/allProducts">All Products</a>
                    </li>



                    <% if (user) { %>

                        <li class="nav-item d-flex align-items-center gap-3 ms-3">
                            <!-- Wishlist -->
                            <a class="nav-link p-0 position-relative" href="/wishlist">
                                <i class="bi bi-heart fs-5"></i>
                                <% if ((wishlistItemCount || 0)> 0) { %>
                                    <span
                                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger icon-badge">
                                        <%= wishlistItemCount %>
                                    </span>
                                    <% } %>
                            </a>

                            <!-- Cart -->
                            <a class="nav-link p-0 position-relative" href="/cart">
                                <i class="bi bi-cart fs-5"></i>
                                <% if ((cartItemCount || 0)> 0) { %>
                                    <span
                                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger icon-badge">
                                        <%= cartItemCount %>
                                    </span>
                                    <% } %>
                            </a>
                            <!-- User Dropdown -->
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle p-0 d-flex align-items-center" href="#"
                                    id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle fs-5 me-1"></i>
                                    <%= user.name || 'Account' %>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" href="/userProfile"><i
                                                class="bi bi-person me-2"></i>Account</a></li>
                                    <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag me-2"></i>Orders</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li><a class="dropdown-item" href="/logout"><i
                                                class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                                </ul>
                            </div>

            </div>


            <% } else { %>

                <!-- Login -->
                <li class="nav-item ms-3">
                    <a href="/login" class="btn btn-login">Login</a>
                </li>

                <!-- Signup -->
                <li class="nav-item ms-2">
                    <a href="/signup" class="btn signup-btn">Sign Up</a>
                </li>

                <% } %>

                    </ul>

        </div>
        </div>
    </nav>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>