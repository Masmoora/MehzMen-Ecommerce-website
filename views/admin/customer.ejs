<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Management - MehzMen Admin</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin/customer.css">

</head>

<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

      <!-- Main Content -->
      <main class="main-content">
        <h1 class="page-title">Customer Management</h1>

        <!-- Search Section -->
        <div class="search-section">
          <form action="/admin/customers" method="GET" class="search-form" id="searchForm">
            <div class="search-input-group">
              <label for="searchInput" class="form-label">Search Customers</label>
              <input type="text" class="form-control" id="searchInput" name="search"
                placeholder="Search by name or email" value="<%= typeof search !== 'undefined' ? search : '' %>">
              <input type="hidden" name="page" value="1">
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Search
              </button>
              <a href="/admin/customers" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Clear
              </a>
            </div>
          </form>
        </div>

        <!-- Customer Table -->
        <div class="table-container">
          <% if (typeof users !=='undefined' && users.length> 0) { %>
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Customer Name</th>
                  <th>Email</th>
                  <th>Total Orders</th>
                  <th>Account Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(user=> { %>
                  <tr>
                    <td>

                      <%= user.name %>

                    </td>
                    <td>
                      <i class="bi bi-envelope me-2 text-muted"></i>
                      <%= user.email %>
                    </td>
                    <td>
                      <span class="badge bg-info">
                        <%= user.totalOrders || 0 %>
                      </span>
                    </td>
                    <td>
                      <% if (user.isBlocked===false || !user.isBlocked) { %>
                        <span class="badge bg-success">
                          <i class="bi bi-check-circle me-1"></i>Active
                        </span>
                        <% } else { %>
                          <span class="badge bg-danger">
                            <i class="bi bi-x-circle me-1"></i>Blocked
                          </span>
                          <% } %>
                    </td>
                    <td>
                      <% if (!user.isBlocked) { %>
                        <a href="/admin/blockCustomer?id=<%= user._id %>" class="btn btn-danger btn-sm btn-action"
                          onclick="return confirm('Are you sure you want to block <%= user.name %>?')">
                          <i class="bi bi-lock me-1"></i>Block
                        </a>
                        <% } else { %>
                          <a href="/admin/unblockCustomer?id=<%= user._id %>" class="btn btn-success btn-sm btn-action"
                            onclick="return confirm('Are you sure you want to unblock <%= user.name %>?')">
                            <i class="bi bi-unlock me-1"></i>Unblock
                          </a>
                          <% } %>
                    </td>

                  </tr>
                  <% }); %>
              </tbody>
            </table>
            <% } else { %>
              <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No customers found</h5>
                <p class="text-muted">
                  <% if (typeof search !=='undefined' && search) { %>
                    No customers match your search criteria.
                    <% } else { %>
                      There are no customers
                      <% } %>
                </p>
              </div>
              <% } %>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages> 1) { %>
          <div class="d-flex justify-content-end me-5 mt-5">
            <nav>
              <ul class="pagination">
                <% if (page> 1) { %>
                  <li class="page-item">
                    <a class="page-link" style="background-color: #1e293b; color: #ffffff"
                      href="?page=<%= page - 1 %>&search=<%= search %>">Prev</a>
                  </li>
                  <% } %>

                    <% for (let i=1; i <=totalPages; i++) { %>
                      <li class="page-item <%= page === i ? 'active' : '' %>">
                        <a class="page-link" style="background-color: #1e293b; color: #ffffff"
                          href="?page=<%= i %>&search=<%= search %>">
                          <%= i %>
                        </a>
                      </li>
                      <% } %>

                        <% if (page < totalPages) { %>
                          <li class="page-item">
                            <a class="page-link" style="background-color: #1e293b; color: #ffffff"
                              href="?page=<%= page + 1 %>&search=<%= search %>">Next</a>
                          </li>
                          <% } %>
              </ul>
            </nav>
          </div>
          <% } %>
            <!-- PAGINATION -->
      </main>

      <!-- Footer Partial -->
      <%- include("../../views/partials/admin/footer")%>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>