<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found - MehzMen Admin</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/pageerror.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

</head>

<body>

  <!-- Main Content -->
  <main class="main-content">
    <div class="error-container">
      <div class="error-card">
        <!-- Error Icon -->
        <div class="error-icon">
          <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <!-- Error Title -->
        <h1 class="error-title">Oops!</h1>

        <!-- Error Message -->
        <p class="error-message">Error 404 - Page not found</p>

        <!-- Error Description -->
        <p class="error-description">
          The page you are trying to access is not available. You may go back to the admin dashboard.
        </p>

        <!-- Back to Dashboard Button -->
        <a href="/admin/dashboard" class="error-button">
          <i class="bi bi-house-door me-2"></i>Back to Dashboard
        </a>
      </div>
    </div>
  </main>
</body>

</html>