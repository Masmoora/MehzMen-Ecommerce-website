<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Add Product</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- CropperJS -->
  <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/addProducts.css">
  <!-- SweetAlert -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

  <%- include("../../views/partials/admin/header") %>
    <%- include("../../views/partials/admin/sidebar") %>

      <main class="p-4">
        <h1 class="page-title mb-3">Add Product</h1>

        <form id="productForm" method="post" enctype="multipart/form-data">

          <div class="card p-3 mb-4">
            <h5 class="mb-3">Product Details</h5>
            <div class="mb-2">
              <label class="form-label">Product Name</label>
              <input class="form-control" name="name">
            </div>
            <div class="mb-2">
              <label class="form-label">Product Description</label>
              <textarea class="form-control" name="description" rows="3"></textarea>
            </div>

            <div class="mb-2">
              <label class="form-label">Brand</label>
              <select class="form-select" name="brand">
                <option value="">Select Brand</option>
                <% brands.forEach(b=> { %>
                  <option value="<%= b._id %>">
                    <%= b.name %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="mb-2">
              <label class="form-label">Category</label>
              <select class="form-select" name="category">
                <option value="">Select Category</option>
                <% categories.forEach(c=> { %>
                  <option value="<%= c._id %>">
                    <%= c.name %>
                  </option>
                  <% }) %>
              </select>
            </div>

            <div class="mb-2">
              <label class="form-label">Product Status</label>
              <select class="form-select" name="status">
                <option value="">Select Status</option>
                <option value="available">Available</option>
                <option value="out_of_stock">Out of Stock</option>
                <option value="discontinued">Discontinued</option>
              </select>
            </div>
          </div>

          <div class="card p-3">
            <div class="d-flex justify-content-between">
              <h5>Variants</h5>
              <button type="button" class="btn btn-success btn-sm" onclick="addVariant()">+ Add Variant</button>
            </div>
            <div id="variantContainer"></div>
          </div>

          <button class="btn btn-primary mt-3">Save Product</button>
        </form>
      </main>

      <div class="modal fade" id="cropModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-body"><img id="cropImage"></div>
            <div class="modal-footer">
              <button id="cropSave" class="btn btn-success">Crop</button>
              <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
          </div>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>

      <script>
        let variantCount = 0;
        let cropper;
        let imageQueue = [];
        let currentIndex = 0;
        let activeVariantIndex;
        let croppedImagesMap = {};

        const cropModalEl = document.getElementById('cropModal');
        const cropModal = new bootstrap.Modal(cropModalEl);
        const cropImageEl = document.getElementById('cropImage');
        const cropSaveBtn = document.getElementById('cropSave');

        function addVariant() {
          const variantKey = variantCount;
          const html = `
  <div class="variant-box" data-variant-index="${variantKey}">
    <button type="button" class="btn btn-danger btn-sm delete-variant-btn" onclick="deleteVariant(${variantKey})">
      <i class="bi bi-trash"></i> Delete
    </button>
    <div class="row g-2 mb-2">
      <div class="col-md-3">
        <label class="form-label">Size</label>
        <select class="form-select" name="variants[${variantKey}][size]" required>
          <option value="">Select Size</option>
          <option>S</option><option>M</option><option>L</option><option>XL</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Color</label>
        <select class="form-select" name="variants[${variantKey}][color]" required>
          <option value="">Select Color</option>
          <option>Black</option><option>Blue</option><option>White</option><option>Green</option><option>Yellow</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Price</label>
        <input type="number" class="form-control" name="variants[${variantKey}][price]" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Stock</label>
        <input type="number" class="form-control" name="variants[${variantKey}][stock]" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Active</label>
        <select class="form-select" name="variants[${variantKey}][isActive]">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>
    </div>

    <div class="mb-2">
      <label class="form-label">SKU</label>
      <input type="text" class="form-control" name="variants[${variantKey}][sku]" placeholder="SKU Code">
    </div>

    <div class="mb-2">
      <label class="form-label">Images (3 required)</label>
      <input type="file" multiple accept="image/*" class="form-control" data-variant-index="${variantKey}" onchange="handleImages(this)">
    </div>

    <div id="preview-${variantKey}" class="mt-2"></div>
  </div>`;

          document.getElementById('variantContainer').insertAdjacentHTML('beforeend', html);
          croppedImagesMap[variantKey] = [];
          variantCount++;
        }

        function handleImages(input) {
          const index = Number(input.dataset.variantIndex);
          imageQueue = Array.from(input.files);
          currentIndex = 0;
          activeVariantIndex = index;
          if (imageQueue.length > 0) {
            openCropper();
          }
        }

        function openCropper() {
          const reader = new FileReader();
          reader.onload = e => {
            cropImageEl.src = e.target.result;
            cropModal.show();
          };
          reader.readAsDataURL(imageQueue[currentIndex]);
        }

        cropModalEl.addEventListener('shown.bs.modal', () => {
          if (cropper) cropper.destroy();
          cropper = new Cropper(cropImageEl, {
            aspectRatio: NaN,
            viewMode: 1,
            autoCropArea: 1,
            movable: true,
            zoomable: true,
            cropBoxMovable: true,
            cropBoxResizable: true,
            ready() {
              const data = this.cropper.getImageData();
              this.cropper.setCropBoxData({
                left: data.left,
                top: data.top,
                width: data.width,
                height: data.height
              });
            }
          });
        });

        cropSaveBtn.addEventListener('click', () => {
          cropper.getCroppedCanvas({ width: 800, height: 800 }).toBlob(blob => {
            const file = new File([blob], `img-${Date.now()}.jpg`, { type: 'image/jpeg' });
            croppedImagesMap[activeVariantIndex].push(file);

            const previewWrapper = document.createElement('div');
            previewWrapper.className = 'preview-wrapper';
            previewWrapper.dataset.fileIndex = croppedImagesMap[activeVariantIndex].length - 1;
            previewWrapper.dataset.variantIndex = activeVariantIndex;

            const img = document.createElement('img');
            img.src = URL.createObjectURL(blob);
            img.className = 'preview-img';

            const deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'delete-img';
            deleteBtn.title = 'Delete Image';
            deleteBtn.innerHTML = '×';
            deleteBtn.onclick = function () {
              deleteNewImage(this);
            };

            previewWrapper.appendChild(img);
            previewWrapper.appendChild(deleteBtn);
            document.getElementById(`preview-${activeVariantIndex}`).appendChild(previewWrapper);

            cropModal.hide();
            currentIndex++;
            if (currentIndex < imageQueue.length) {
              openCropper();
            } else {
              const fileInput = document.querySelector(`input[data-variant-index="${activeVariantIndex}"]`);
              if (fileInput) {
                fileInput.value = '';
              }
            }
          });
        });

        function deleteNewImage(buttonElement) {
          const wrapper = buttonElement.closest('.preview-wrapper');
          const fileIndex = parseInt(wrapper.dataset.fileIndex, 10);
          const variantIndex = parseInt(wrapper.dataset.variantIndex, 10);

          if (croppedImagesMap[variantIndex] && croppedImagesMap[variantIndex][fileIndex]) {
            const img = wrapper.querySelector('img');
            if (img && img.src.startsWith('blob:')) {
              URL.revokeObjectURL(img.src);
            }

            croppedImagesMap[variantIndex].splice(fileIndex, 1);
            wrapper.remove();

            const previewDiv = document.getElementById(`preview-${variantIndex}`);
            if (previewDiv) {
              const remainingWrappers = previewDiv.querySelectorAll('.preview-wrapper');
              remainingWrappers.forEach((w, idx) => {
                w.dataset.fileIndex = idx;
              });
            }
          }
        }

        function deleteVariant(variantIndex) {
          const variantBox = document.querySelector(`.variant-box[data-variant-index="${variantIndex}"]`);
          if (variantBox) {
            const previews = variantBox.querySelectorAll('.preview-wrapper img');
            previews.forEach(img => {
              if (img.src.startsWith('blob:')) {
                URL.revokeObjectURL(img.src);
              }
            });
            delete croppedImagesMap[variantIndex];
            variantBox.remove();
          }
        }
      </script>
      <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
      <script>
        document.getElementById('productForm').addEventListener('submit', async e => {
          e.preventDefault();

          const formData = new FormData(e.target);

          // Validate minimum images per variant
          let hasError = false;
          const variantBoxes = document.querySelectorAll('.variant-box');
          variantBoxes.forEach(box => {
            const variantIndex = box.dataset.variantIndex;
            const imagesCount = (croppedImagesMap[variantIndex] || []).length;
            if (imagesCount < 3) {
              hasError = true;
              Swal.fire(
                'Validation Error',
                `Each variant must have at least 3 images. One variant has only ${imagesCount} image(s).`,
                'error'
              );
            }
          });

          if (hasError) {
            return;
          }

          Object.keys(croppedImagesMap).forEach(variantIndex => {
            croppedImagesMap[variantIndex].forEach(file => {
              formData.append(`variants[${variantIndex}][images]`, file);
            });
          });

          try {
            const res = await axios.post('/admin/addProducts', formData, {
              headers: { 'Content-Type': 'multipart/form-data' }
            });

            Swal.fire('Success', res.data.message, 'success')
              .then(() => window.location.href = '/admin/products');

          } catch (err) {
            Swal.fire(
              'Error',
              err.response?.data?.message || 'Something went wrong',
              'error'
            );
          }
        });
      </script>

</body>

</html>