<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Product</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://unpkg.com/cropperjs/dist/cropper.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    body {
      background-color: #f5f7fa;
      padding-top: 70px;
      padding-left: 260px;
    }
    .variant-box {
      border: 1px dashed #ccc;
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 8px;
      background: #fff;
    }
    .preview-img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      margin-right: 5px;
      margin-bottom: 5px;
      border-radius: 6px;
    }
  </style>
</head>

<body>

<%- include("../../views/partials/admin/header") %>
<%- include("../../views/partials/admin/sidebar") %>

<main class="p-4">
<h1 class="page-title mb-3">Add Product</h1>

<form id="productForm" method="post" enctype="multipart/form-data">

<!-- PRODUCT DETAILS -->
<div class="card p-3 mb-4">
  <h5 class="mb-3">Product Details</h5>

  <div class="mb-3">
    <label class="form-label">Product Name</label>
    <input type="text" class="form-control" name="name" required>
  </div>

  <div class="mb-3">
    <label class="form-label">Description</label>
    <textarea class="form-control" name="description" rows="3"></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Brand</label>
    <select class="form-select" name="brand" required>
      <option value="">Select Brand</option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>"><%= b.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Category</label>
    <select class="form-select" name="category" required>
      <option value="">Select Category</option>
      <% categories.forEach(cat => { %>
    <option value="<%= cat._id %>"
      <%= category && category.toString() === cat._id.toString() ? 'selected' : '' %>>
      <%= cat.name %>
    </option>
  <% }) %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Status</label>
    <select name="status" class="form-select" required>
      <option value="">Select Status</option>
      <option value="available">Available</option>
      <option value="out_of_stock">Out of Stock</option>
      <option value="discontinued">Discontinued</option>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Price</label>
    <input type="number" class="form-control" name="price" required>
  </div>
</div>

<!-- VARIANTS -->
<div class="card p-3">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="mb-0">Variants</h5>
    <button type="button" class="btn btn-sm btn-success" onclick="addVariant()">+ Add Variant</button>
  </div>

  <div id="variantContainer"></div>
</div>

<button class="btn btn-primary mt-4">Save Product</button>
</form>
</main>

<!-- CROP MODAL -->
<<div class="modal fade" id="cropperModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content rounded-4 shadow-lg">
      <div class="modal-body p-0">
        <img id="imageToCrop" class="w-100" />
      </div>
      <div class="modal-footer">
        <button type="button" id="cropButton" class="btn btn-success">
          ✂ Crop
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>


<script src="https://unpkg.com/cropperjs/dist/cropper.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
let variantCount = 0;
let cropper = null;
let imageQueue = [];
let currentIndex = 0;
let activeVariantIndex = null;
let totalImages = 0;
let croppedImagesMap = {};

// 🔴 IMPORTANT DOM REFERENCES
const cropModalEl = document.getElementById("cropModal");
const cropImageEl = document.getElementById("cropImage");
const cropSaveBtn = document.getElementById("cropSave");

const cropModal = new bootstrap.Modal(cropModalEl);

// ADD VARIANT
function addVariant() {
  const html = `
  <div class="variant-box">
    <h6>Variant</h6>

    <input name="variants[${variantCount}][size]" class="form-control mb-2" placeholder="Size">
    <input name="variants[${variantCount}][color]" class="form-control mb-2" placeholder="Color">
    <input name="variants[${variantCount}][stock]" type="number" class="form-control mb-2" placeholder="Stock">

    <input type="file" multiple accept="image/*"
      name="variants[${variantCount}][images]"
      class="form-control"
      onchange="handleImages(this, ${variantCount})">

    <div id="preview-${variantCount}" class="d-flex flex-wrap mt-2"></div>
  </div>`;

  document.getElementById("variantContainer")
    .insertAdjacentHTML("beforeend", html);

  variantCount++;
}

// IMAGE SELECTION
function handleImages(input, index) {
  if (!input.files.length) return;

  imageQueue = Array.from(input.files);
  currentIndex = 0;
  activeVariantIndex = index;

  if (!croppedImagesMap[index]) {
    croppedImagesMap[index] = [];
  }

  openCropper();
}

// OPEN CROPPER FOR CURRENT IMAGE
function openCropper() {
  const file = imageQueue[currentIndex];
  const reader = new FileReader();

  reader.onload = e => {
    cropImageEl.src = e.target.result;

    cropModal.show();

    // Wait until modal is visible
    cropModalEl.addEventListener(
      "shown.bs.modal",
      () => {
        if (cropper) cropper.destroy();

        cropper = new Cropper(cropImageEl, {
          aspectRatio: 1,
          viewMode: 1,
          autoCropArea: 1
        });
      },
      { once: true }
    );
  };

  reader.readAsDataURL(file);
}

// CROP BUTTON
cropSaveBtn.addEventListener("click", () => {
  if (!cropper) return;

  cropper.getCroppedCanvas({ width: 800, height: 800 })
    .toBlob(blob => {
      const file = new File(
        [blob],
        `variant-${Date.now()}.jpg`,
        { type: "image/jpeg" }
      );

      croppedImagesMap[activeVariantIndex].push(file);

      const img = document.createElement("img");
      img.src = URL.createObjectURL(blob);
      img.className = "preview-img";

      document
        .getElementById(`preview-${activeVariantIndex}`)
        .appendChild(img);

      totalImages++;

      cropper.destroy();
      cropper = null;
      cropModal.hide();

      currentIndex++;
      if (currentIndex < imageQueue.length) {
        openCropper(); // next image
      }
    });
});

// FORM SUBMIT
document.getElementById("productForm").addEventListener("submit", e => {
  if (totalImages < 3) {
    e.preventDefault();
    Swal.fire("Error", "Minimum 3 images required for product", "error");
    return;
  }

  Object.keys(croppedImagesMap).forEach(index => {
    const dt = new DataTransfer();
    croppedImagesMap[index].forEach(file => dt.items.add(file));

    const input = document.querySelector(
      `input[name="variants[${index}][images]"]`
    );

    if (input) input.files = dt.files;
  });
});
</script>


</body>
</html>
