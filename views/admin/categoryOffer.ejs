<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Category Offers - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    body { background: #f5f7fb; padding-top: 70px; padding-left: 260px; min-height: 100vh; display: flex; flex-direction: column; }
    .main-content { flex: 1; padding: 2rem; margin-bottom: 80px; }
  </style>
</head>
<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="mb-0">Category Offer Management</h2>
      <button type="button" class="btn btn-success" onclick="openAddOfferModal()">
        <i class="bi bi-plus-circle me-1"></i> Add Offer
      </button>
    </div>

    <form class="row g-2 mb-3" method="GET" action="/admin/categoryOffers">
      <div class="col-md-4">
        <input
          type="text"
          class="form-control"
          name="search"
          placeholder="Search by offer title"
          value="<%= search || '' %>"
        />
      </div>
      <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-primary w-100" type="submit">Search</button>
        <a href="/admin/categoryOffers" class="btn btn-outline-secondary w-100">Clear</a>
      </div>
    </form>

    <div class="table-responsive bg-white border rounded">
      <table class="table table-bordered table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th>Category Name</th>
            <th>Offer Title</th>
            <th>Discount Type</th>
            <th>Discount Value</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th style="width: 200px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!offers || offers.length === 0) { %>
            <tr><td colspan="8" class="text-center py-3">No offers found</td></tr>
          <% } else { %>
            <% const now = new Date(); %>
            <% offers.forEach(offer => { %>
              <% const end = new Date(offer.endDate); %>
              <% const isExpired = end < now; %>
              <% let statusLabel = offer.status === 'active' ? 'Active' : 'Inactive'; %>
              <% let statusClass = offer.status === 'active' ? 'bg-success' : 'bg-danger'; %>
              <% if (isExpired) { statusLabel = 'Expired'; statusClass = 'bg-secondary'; } %>
              <tr>
                <td><%= offer.categoryId ? offer.categoryId.name : 'N/A' %></td>
                <td><%= offer.offerTitle %></td>
                <td class="text-capitalize"><%= offer.discountType %></td>
                <td>
                  <% if (offer.discountType === 'percentage') { %>
                    <%= offer.discountValue %>%
                  <% } else { %>
                    ₹<%= offer.discountValue %>
                  <% } %>
                </td>
                <td><%= new Date(offer.startDate).toLocaleDateString('en-IN') %></td>
                <td><%= new Date(offer.endDate).toLocaleDateString('en-IN') %></td>
                <td>
                  <span class="badge <%= statusClass %>">
                    <%= statusLabel %>
                  </span>
                </td>
                <td>
                  <button
                    type="button"
                    class="btn btn-sm btn-warning mb-1 editBtn"
                    data-offer='<%- JSON.stringify(offer) %>'>
                    Edit
                  </button>
                  <button
                    type="button"
                    class="btn btn-sm <%= offer.status === 'active' ? 'btn-danger' : 'btn-success' %> mb-1"
                    onclick="toggleOffer('<%= offer._id %>')">
                    <%= offer.status === 'active' ? 'Deactivate' : 'Activate' %>
                  </button>
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-danger mb-1"
                    onclick="deleteOffer('<%= offer._id %>')">
                    Delete
                  </button>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Offer Modal -->
    <div class="modal fade" id="offerModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header bg-dark text-white">
            <h5 class="modal-title" id="modalTitle">Add Offer</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <form id="modalForm">
            <div class="modal-body">
              <input type="hidden" id="offerId" />
              <input type="hidden" id="mode" value="add" />

              <div class="mb-3" id="categorySelectWrapper">
                <label class="form-label">Category</label>
                <select id="categoryId" class="form-select">
                  <option value="">Select Category</option>
                  <% if (categories && categories.length) { %>
                    <% categories.forEach(c => { %>
                      <option value="<%= c._id %>"><%= c.name %></option>
                    <% }); %>
                  <% } %>
                </select>
                <small class="text-danger" id="categoryError"></small>
              </div>

              <div class="mb-3 d-none" id="categoryReadonlyWrapper">
                <label class="form-label">Category</label>
                <input type="text" id="categoryNameReadonly" class="form-control" readonly />
              </div>

              <div class="mb-3">
                <label class="form-label">Offer Title</label>
                <input type="text" id="offerTitle" class="form-control" />
                <small class="text-danger" id="offerTitleError"></small>
              </div>

              <div class="mb-3">
                <label class="form-label">Discount Type</label>
                <select id="discountType" class="form-select">
                  <option value="">Select</option>
                  <option value="percentage">Percentage</option>
                  <option value="fixed">Fixed (₹)</option>
                </select>
                <small class="text-danger" id="discountTypeError"></small>
              </div>

              <div class="mb-3">
                <label class="form-label">Discount Value</label>
                <input type="number" id="discountValue" class="form-control" min="1" />
                <small class="text-danger" id="discountValueError"></small>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Start Date</label>
                  <input type="date" id="startDate" class="form-control" />
                  <small class="text-danger" id="startDateError"></small>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label">End Date</label>
                  <input type="date" id="endDate" class="form-control" />
                  <small class="text-danger" id="endDateError"></small>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" id="submitBtn" class="btn btn-dark">Create</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <% if (totalPages && totalPages > 1) { %>
      <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
          <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="/admin/categoryOffers?page=<%= page - 1 %>&search=<%= search %>">Prev</a>
          </li>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= page === i ? 'active' : '' %>">
              <a class="page-link" href="/admin/categoryOffers?page=<%= i %>&search=<%= search %>"><%= i %></a>
            </li>
          <% } %>
          <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="/admin/categoryOffers?page=<%= page + 1 %>&search=<%= search %>">Next</a>
          </li>
        </ul>
      </nav>
    <% } %>
  </main>

    <%- include("../../views/partials/admin/footer")%>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const modalInstance = new bootstrap.Modal(document.getElementById('offerModal'));
    const form = document.getElementById('modalForm');

    function clearErrors() {
      document.querySelectorAll('.text-danger').forEach(el => el.innerText = '');
    }

    function showError(id, msg) {
      const el = document.getElementById(id);
      if (el) el.innerText = msg;
    }

    function openAddOfferModal() {
      form.reset();
      clearErrors();
      document.getElementById('mode').value = 'add';
      document.getElementById('offerId').value = '';
      document.getElementById('modalTitle').innerText = 'Add Offer';
      document.getElementById('submitBtn').innerText = 'Create';

      document.getElementById('categorySelectWrapper').classList.remove('d-none');
      document.getElementById('categoryReadonlyWrapper').classList.add('d-none');

      modalInstance.show();
    }

    document.querySelectorAll('.editBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        const offer = JSON.parse(btn.dataset.offer);
        form.reset();
        clearErrors();

        document.getElementById('mode').value = 'edit';
        document.getElementById('offerId').value = offer._id;
        document.getElementById('modalTitle').innerText = 'Edit Offer';
        document.getElementById('submitBtn').innerText = 'Update';

        document.getElementById('offerTitle').value = offer.offerTitle;
        document.getElementById('discountType').value = offer.discountType;
        document.getElementById('discountValue').value = offer.discountValue;
        document.getElementById('startDate').value = new Date(offer.startDate).toISOString().split('T')[0];
        document.getElementById('endDate').value = new Date(offer.endDate).toISOString().split('T')[0];

        document.getElementById('categorySelectWrapper').classList.add('d-none');
        document.getElementById('categoryReadonlyWrapper').classList.remove('d-none');
        document.getElementById('categoryNameReadonly').value =
          offer.categoryId && offer.categoryId.name ? offer.categoryId.name : 'N/A';

        modalInstance.show();
      });
    });

    function validateForm() {
      clearErrors();
      let valid = true;

      const mode = document.getElementById('mode').value;
      const categoryId = document.getElementById('categoryId').value;
      const title = document.getElementById('offerTitle').value.trim();
      const discountType = document.getElementById('discountType').value;
      const discountValue = document.getElementById('discountValue').value;
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;

      if (mode === 'add' && !categoryId) {
        showError('categoryError', 'Category required');
        valid = false;
      }
      if (!title) {
        showError('offerTitleError', 'Offer title required');
        valid = false;
      }
      if (!discountType) {
        showError('discountTypeError', 'Discount type required');
        valid = false;
      }
      if (!discountValue || Number(discountValue) <= 0) {
        showError('discountValueError', 'Discount must be greater than 0');
        valid = false;
      }
      if (discountType === 'percentage') {
        const v = Number(discountValue);
        if (v < 1 || v > 90) {
          showError('discountValueError', 'Percentage must be between 1 and 90');
          valid = false;
        }
      }
      if (!startDate) {
        showError('startDateError', 'Start date required');
        valid = false;
      }
      if (!endDate) {
        showError('endDateError', 'End date required');
        valid = false;
      }
      if (startDate && endDate && new Date(startDate) >= new Date(endDate)) {
        showError('endDateError', 'End date must be after start date');
        valid = false;
      }

      return valid;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateForm()) return;

      const mode = document.getElementById('mode').value;
      const offerId = document.getElementById('offerId').value;

      const payload = {
        offerTitle: document.getElementById('offerTitle').value.trim(),
        discountType: document.getElementById('discountType').value,
        discountValue: Number(document.getElementById('discountValue').value),
        startDate: document.getElementById('startDate').value,
        endDate: document.getElementById('endDate').value
      };

      if (mode === 'add') {
        payload.categoryId = document.getElementById('categoryId').value;
      } else {
        payload.id = offerId;
      }

      const url = mode === 'add' ? '/admin/createCategoryOffer' : '/admin/updateCategoryOffer';
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (!res.ok || !data.success) {
        return Swal.fire('Error', data.message || 'Something went wrong', 'error');
      }

      await Swal.fire('Success', data.message || 'Success', 'success');
      location.reload();
    });

    async function deleteOffer(id) {
      const result = await Swal.fire({
        title: 'Delete this offer?',
        text: 'This action cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, delete',
        cancelButtonText: 'Cancel'
      });
      if (!result.isConfirmed) return;

      const res = await fetch('/admin/deleteCategoryOffer/' + id);
      const data = await res.json();

      if (!res.ok || !data.success) {
        return Swal.fire('Error', data.message || 'Failed to delete offer', 'error');
      }

      await Swal.fire('Deleted', data.message || 'Offer deleted', 'success');
      location.reload();
    }

    async function toggleOffer(id) {
      const result = await Swal.fire({
        title: 'Change offer status?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes',
        cancelButtonText: 'Cancel'
      });
      if (!result.isConfirmed) return;

      const res = await fetch('/admin/toggleCategoryOffer/' + id);
      const data = await res.json();

      if (!res.ok || !data.success) {
        return Swal.fire('Error', data.message || 'Failed to change status', 'error');
      }

      await Swal.fire('Updated', data.message, 'success');
      location.reload();
    }
  </script>
</body>
</html>

