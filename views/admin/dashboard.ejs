<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - MehzMen</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/dashboard.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
   <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

      <!-- Main Content -->
   <main class="main-content">
    <div class="container-fluid px-0">
      <div class="row">
        <div class="col-12">
          
          <h1 class="page-title">Admin Dashboard</h1>
        </div>
      </div>

      <div class="row mb-4 g-3">
        <div class="col-md-3 offset-md-9">
          <select name="filter-select" id="filter-select" class="form-select">
            <option value="yearly">Yearly</option>
            <option value="monthly" selected>Monthly</option>
            <option value="weekly">Weekly</option>
            <option value="custom">Custom Range</option>
          </select>
        </div>
        <div class="col-md-3 custom-date-range d-none">
          <label for="start-date" class="form-label">Start Date</label>
          <input type="date" id="start-date" class="form-control">
        </div>
        <div class="col-md-3 custom-date-range d-none">
          <label for="end-date" class="form-label">End Date</label>
          <input type="date" id="end-date" class="form-control">
        </div>
      </div>

      <div class="row text-center mb-4 g-4">
        <div class="col-md-3">
          <div class="dashboard-card">
            <div class="dashboard-icon icon-revenue"><i class="fas fa-chart-line"></i></div>
            <h6 class="text-muted">Total Revenue</h6>
            <h4 class="fw-bold text-dark" id="total-revenue">₹0</h4>
          </div>
        </div>
        <div class="col-md-3">
          <div class="dashboard-card">
            <div class="dashboard-icon icon-orders"><i class="fas fa-shopping-cart"></i></div>
            <h6 class="text-muted">Total Orders</h6>
            <h4 class="fw-bold text-dark" id="total-order">0</h4>
          </div>
        </div>
        <div class="col-md-3">
          <div class="dashboard-card">
            <div class="dashboard-icon icon-cancels"><i class="fas fa-times-circle"></i></div>
            <h6 class="text-muted">Total Cancels</h6>
            <h4 class="fw-bold text-dark" id="total-cancel">0</h4>
          </div>
        </div>
        <div class="col-md-3">
          <div class="dashboard-card">
            <div class="dashboard-icon icon-returns"><i class="fas fa-undo-alt"></i></div>
            <h6 class="text-muted">Total Returns</h6>
            <h4 class="fw-bold text-dark" id="total-return">0</h4>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-lg-8">
          <div class="card">
            <div class="card-header section-header">Sales Overview</div>
            <div class="card-body">
              <canvas id="salesChart" height="120"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card">
            <div class="card-header section-header">Order Status</div>
            <div class="card-body">
              <canvas id="orderStatusPie" height="200"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="row mt-3 g-3">
        <div class="col-md-4">
          <div class="card">
            <div class="card-header section-header">Top Products</div>
            <div class="card-body">
              <ul class="list-group" id="top-products">
                <li class="list-group-item">Loading...</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-header section-header">Top Categories</div>
            <div class="card-body">
              <ul class="list-group" id="top-categories">
                <li class="list-group-item">Loading...</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-header section-header">Top Brands</div>
            <div class="card-body">
              <ul class="list-group" id="top-brands">
                <li class="list-group-item">Loading...</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const selectFilter = document.getElementById('filter-select');
      const customDateInput = document.querySelectorAll('.custom-date-range');
      const salesChartCanvas = document.getElementById('salesChart').getContext('2d');
      const pieChartCanvas = document.getElementById('orderStatusPie').getContext('2d');
      let salesChart;
      let pieChart;

      async function loadDashboardData() {
        document.body.style.cursor = 'wait';
        try {
          const filter = selectFilter.value;
          let url = `/admin/dashboard-data?filter=${encodeURIComponent(filter)}`;

          if (filter === 'custom') {
            const start = document.getElementById('start-date').value;
            const end = document.getElementById('end-date').value;

            if (!start || !end) return;

            const startDate = new Date(start);
            const endDate = new Date(end);
            const today = new Date();
            startDate.setHours(0, 0, 0, 0);
            endDate.setHours(0, 0, 0, 0);
            today.setHours(0, 0, 0, 0);

            if (startDate > today || endDate > today) {
              await Swal.fire('Invalid Dates', 'Start and end dates must not be in the future', 'warning');
              return;
            }
            if (startDate > endDate) {
              await Swal.fire('Invalid Dates', 'Start date cannot be greater than end date', 'warning');
              return;
            }

            url += `&start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;
          }

          const response = await fetch(url);
          if (!response.ok) throw new Error('Failed to fetch dashboard data');
          const data = await response.json();

          const labels = (data.salesChart || []).map((d) => {
            const id = d._id || {};
            if ('day' in id && 'month' in id) return `${id.day}/${id.month}/${id.year}`;
            if ('month' in id) {
              const monthNames = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
              return `${monthNames[id.month] || id.month}/${id.year}`;
            }
            if ('week' in id) return `Week ${id.week} - ${id.year}`;
            return `${id.year || ''}`;
          });

          const salesValues = (data.salesChart || []).map((d) => d.totalSales || 0);

          if (salesChart) salesChart.destroy();
          salesChart = new Chart(salesChartCanvas, {
            type: 'line',
            data: {
              labels,
              datasets: [{
                label: 'Total Sales (INR)',
                data: salesValues,
                backgroundColor: 'rgba(54, 162, 235, 0.2)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 2,
                tension: 0.2,
                fill: true
              }]
            },
            options: {
              responsive: true,
              scales: { y: { beginAtZero: true } },
              plugins: { legend: { display: true } }
            }
          });

          const pieLabels = (data.orderStatus || []).map((d) => d._id);
          const pieValues = (data.orderStatus || []).map((d) => d.count);
          const pieColors = ['#198754', '#dc3545', '#ffc107', '#0d6efd', '#6f42c1', '#fd7e14', '#20c997', '#0dcaf0', '#6610f2'];

          if (pieChart) pieChart.destroy();
          pieChart = new Chart(pieChartCanvas, {
            type: 'pie',
            data: {
              labels: pieLabels,
              datasets: [{ data: pieValues, backgroundColor: pieColors }]
            }
          });

          document.getElementById('total-revenue').textContent = `₹${Number(data.totalRevenue || 0).toLocaleString('en-IN')}`;
          document.getElementById('total-order').textContent = Number(data.totalOrders || 0).toLocaleString('en-IN');
          document.getElementById('total-cancel').textContent = Number(data.totalCancels || 0).toLocaleString('en-IN');
          document.getElementById('total-return').textContent = Number(data.totalReturns || 0).toLocaleString('en-IN');

          const productList = document.getElementById('top-products');
          productList.innerHTML = '';
          (data.bestProducts || []).forEach((p) => {
            productList.innerHTML += `
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>${p.name}</span>
                <span class="badge bg-primary rounded-pill">${p.totalQty}</span>
              </li>`;
          });
          if (!productList.innerHTML) productList.innerHTML = '<li class="list-group-item">No data</li>';

          const categoryList = document.getElementById('top-categories');
          categoryList.innerHTML = '';
          (data.bestCategories || []).forEach((c) => {
            categoryList.innerHTML += `
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>${c.name}</span>
                <span class="badge bg-info rounded-pill">${c.totalQty}</span>
              </li>`;
          });
          if (!categoryList.innerHTML) categoryList.innerHTML = '<li class="list-group-item">No data</li>';

          const brandList = document.getElementById('top-brands');
          brandList.innerHTML = '';
          (data.bestBrands || []).forEach((b) => {
            brandList.innerHTML += `
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>${b.name}</span>
                <span class="badge bg-warning rounded-pill">${b.totalQty}</span>
              </li>`;
          });
          if (!brandList.innerHTML) brandList.innerHTML = '<li class="list-group-item">No data</li>';
        } catch (error) {
          console.error('Dashboard data load failed', error);
        } finally {
          document.body.style.cursor = 'default';
        }
      }

      selectFilter.addEventListener('change', () => {
        const isCustom = selectFilter.value === 'custom';
        customDateInput.forEach((el) => {
          el.classList.toggle('d-none', !isCustom);
        });
        if (!isCustom) loadDashboardData();
      });

      document.getElementById('start-date').addEventListener('change', () => {
        if (selectFilter.value === 'custom') loadDashboardData();
      });
      document.getElementById('end-date').addEventListener('change', () => {
        if (selectFilter.value === 'custom') loadDashboardData();
      });

      loadDashboardData();
    });
  </script>
</body>

</html>