<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category Management - MehzMen Admin</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin/category.css">
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

      <!-- Main Content -->
      <main class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="page-title mb-0">Category Management</h1>
          <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="bi bi-plus-circle me-1"></i>Add Category
          </button>
        </div>

        <!-- Search Section -->
        <div class="search-section">
          <form action="/admin/category" method="GET" class="search-form" id="searchForm">
            <div class="search-input-group">
              <label for="searchInput" class="form-label">Search Categories</label>
              <input type="text" class="form-control" id="searchInput" name="search"
                placeholder="Search by category name" value="<%= typeof search !== 'undefined' ? search : '' %>">
              <input type="hidden" name="page" value="1">
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Search
              </button>
              <a href="/admin/category" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Clear
              </a>
            </div>
          </form>
        </div>

        <!-- Category Table -->
        <div class="table-container">
          <% if (typeof categories !=='undefined' && categories.length> 0) { %>
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Category Image</th>
                  <th>Category Name</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% const startIndex=(page - 1) * 2; categories.forEach((category, index)=> {
                  %>
                  <tr>
                    <td>
                      <%= startIndex + index + 1 %>
                    </td>
                    <td>
                      <% if (category.image) { %>
                        <img src="<%= category.image %>" alt="<%= category.name %>" class="category-image"
                          data-bs-toggle="modal" data-bs-target="#imageModal" data-image-src="<%= category.image %>"
                          data-image-name="<%= category.name %>">
                        <% } else { %>
                          <div class="category-image bg-light d-flex align-items-center justify-content-center">
                            <i class="bi bi-image text-muted"></i>
                          </div>
                          <% } %>
                    </td>
                    <td>

                      <%= category.name %>

                    </td>
                    <td>
                      <span class="description-text description-cell"
                        title="<%= category.description || 'No description' %>">
                        <%= category.description || 'No description' %>
                      </span>
                    </td>
                    <td>
                      <% if (category.isListed===true || category.isListed===undefined) { %>
                        <span class="badge bg-success">
                          <i class="bi bi-check-circle me-1"></i>Listed
                        </span>
                        <% } else { %>
                          <span class="badge bg-danger">
                            <i class="bi bi-x-circle me-1"></i>Unlisted
                          </span>
                          <% } %>
                    </td>
                    <td>
                      <!-- Edit Button (placeholder - can be implemented later) -->
                      <button class="btn btn-primary btn-sm btn-action" data-bs-toggle="modal"
                        data-bs-target="#editCategoryModal" data-id="<%= category._id %>"
                        data-name="<%= category.name %>" data-description="<%= category.description %>"
                        data-image="<%= category.image %>" data-listed="<%= category.isListed %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <% if(!category.hasOffer){ %>

<button class="btn btn-success btn-sm"
data-bs-toggle="modal"
data-bs-target="#offerModal"
data-category-id="<%= category._id %>"
data-offer-type="add">
<i class="bi bi-tag"></i> Add Offer
</button>

<% } else { %>

<button class="btn btn-primary btn-sm editOfferBtn"
data-category-id="<%= category._id %>">
<i class="bi bi-pencil"></i> Edit Offer
</button>

<button class="btn btn-danger btn-sm removeOfferBtn"
data-category-id="<%= category._id %>">
<i class="bi bi-trash"></i> Remove Offer
</button>

<% } %>


                      <!-- List/Unlist Button -->
                      <% if (category.isListed===true || category.isListed===undefined) { %>
                        <form action="/admin/categories/unlist?id=<%= category._id %>" method="POST" class="d-inline">
                          <% const formPage=typeof currentPage !=='undefined' ? currentPage : (typeof page
                            !=='undefined' ? page : 1); %>
                            <% if (formPage) { %>
                              <input type="hidden" name="page" value="<%= formPage %>">
                              <% } %>
                                <% if (typeof search !=='undefined' && search) { %>
                                  <input type="hidden" name="search" value="<%= search %>">
                                  <% } %>
                                    <button type="submit" class="btn btn-warning btn-sm btn-action" title="Unlist">
                                      <i class="bi bi-eye-slash"></i>
                                    </button>
                        </form>
                        <% } else { %>
                          <form action="/admin/categories/list?id=<%= category._id %>" method="POST" class="d-inline">
                            <% const formPage=typeof currentPage !=='undefined' ? currentPage : (typeof page
                              !=='undefined' ? page : 1); %>
                              <% if (formPage) { %>
                                <input type="hidden" name="page" value="<%= formPage %>">
                                <% } %>
                                  <% if (typeof search !=='undefined' && search) { %>
                                    <input type="hidden" name="search" value="<%= search %>">
                                    <% } %>
                                      <button type="submit" class="btn btn-success btn-sm btn-action" title="List">
                                        <i class="bi bi-eye"></i>
                                      </button>
                          </form>
                          <% } %>
                    </td>
                  </tr>
                  <% }); %>
              </tbody>
            </table>
            <% } else { %>
              <div class="empty-state">
                <i class="bi bi-tags"></i>
                <h5>No categories found</h5>
                <p class="text-muted">
                  <% if (typeof search !=='undefined' && search) { %>
                    No categories match your search criteria.
                    <% } else { %>
                      There are no categories in the system yet.
                      <% } %>
                </p>
              </div>
              <% } %>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages> 1) { %>
          <div class="d-flex justify-content-end me-5 mt-5">
            <nav>
              <ul class="pagination">

                <% if (page> 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= page - 1 %>&search=<%= search || '' %>">
                      Prev
                    </a>
                  </li>
                  <% } %>

                    <% for (let i=1; i <=totalPages; i++) { %>
                      <li class="page-item <%= page === i ? 'active' : '' %>">
                        <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>">
                          <%= i %>
                        </a>
                      </li>
                      <% } %>

                        <% if (page < totalPages) { %>
                          <li class="page-item">
                            <a class="page-link" href="?page=<%= page + 1 %>&search=<%= search || '' %>">
                              Next
                            </a>
                          </li>
                          <% } %>

              </ul>
            </nav>
          </div>
          <% } %>
            <!-- PAGINATION -->

      </main>

      <!-- Add Category Modal -->
      <div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel"
        aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="addCategoryModalLabel">Add New Category</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addCategoryForm" action="/admin/categories/addCategory" method="POST"
              enctype="multipart/form-data">
              <div class="modal-body">
                <div class="mb-3">
                  <label for="categoryName" class="form-label">Category Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="categoryName" name="name">
                  <small id="nameError" class="text-danger"></small>
                </div>
                <div class="mb-3">
                  <label for="categoryDescription" class="form-label">Description</label>
                  <textarea class="form-control" id="categoryDescription" name="description" rows="3"></textarea>
                </div>
                <div class="mb-3">
                  <label for="categoryImage" class="form-label">Category Image</label>
                  <input type="file" class="form-control" id="categoryImage" name="image" accept="image/*">
                  <small class="form-text text-muted">Allowed: JPG, PNG, GIF, WEBP (Max 5MB)</small>
                  <small id="imageError" class="text-danger"></small>
                </div>
                <div class="mb-3">
                  <label class="form-label">Status</label>
                  <div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="isListed" id="statusListed" value="true"
                        checked>
                      <label class="form-check-label" for="statusListed">
                        Listed
                      </label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input" type="radio" name="isListed" id="statusUnlisted" value="false">
                      <label class="form-check-label" for="statusUnlisted">
                        Unlisted
                      </label>
                    </div>
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Category</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <!-- Edit Category Modal -->
      <div class="modal fade" id="editCategoryModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">

            <div class="modal-header">
              <h5 class="modal-title">Edit Category</h5>
              <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="editCategoryForm" action="/admin/categories/editCategory" method="POST"
              enctype="multipart/form-data">
              <div class="modal-body">

                <!-- hidden id -->
                <input type="hidden" name="id" id="editCategoryId">

                <div class="mb-3">
                  <label class="form-label">Category Name</label>
                  <input type="text" class="form-control" name="name" id="editCategoryName" required>
                  <small id="editNameError" class="text-danger"></small>
                </div>

                <div class="mb-3">
                  <label class="form-label">Description</label>
                  <textarea class="form-control" name="description" id="editCategoryDescription"></textarea>
                </div>

                <div class="mb-3">
                  <label class="form-label">Current Image</label><br>
                  <img id="editPreviewImage" style="width:80px;height:80px;border-radius:8px">
                </div>

                <div class="mb-3">
                  <label class="form-label">Change Image</label>
                  <input type="file" class="form-control" name="image" id="editCategoryImage">
                  <small id="editImageError" class="text-danger"></small>
                </div>

                <div class="mb-3">
                  <label>Status</label><br>
                  <input type="radio" name="isListed" value="true" id="editListed"> Listed
                  <input type="radio" name="isListed" value="false" id="editUnlisted"> Unlisted
                </div>

              </div>

              <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary">Update</button>
              </div>

            </form>

          </div>
        </div>
      </div>
  <!-- offer modal -->
   <div class="modal fade" id="offerModal">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Category Offer</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form id="offerForm">

        <div class="modal-body">

          <input type="hidden" id="offerCategoryId">

          <div class="mb-3">
  <label>Offer Title</label>
  <input type="text" id="offerTitle" class="form-control">
  <small id="offerTitleError" class="text-danger"></small>
</div>

<div class="mb-3">
  <label>Discount Type</label>
  <select id="discountType" class="form-control">
    <option value="">Select</option>
    <option value="percentage">Percentage</option>
    <option value="fixed">Fixed</option>
  </select>
  <small id="discountTypeError" class="text-danger"></small>
</div>

<div class="mb-3">
  <label>Discount Value</label>
  <input type="number" id="discountValue" class="form-control">
  <small id="discountValueError" class="text-danger"></small>
</div>

<div class="mb-3">
  <label>Start Date</label>
  <input type="date" id="startDate" class="form-control">
  <small id="startDateError" class="text-danger"></small>
</div>

<div class="mb-3">
  <label>End Date</label>
  <input type="date" id="endDate" class="form-control">
  <small id="endDateError" class="text-danger"></small>
</div>

        </div>

        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-primary">Save Offer</button>
        </div>

      </form>

    </div>
  </div>
</div>


      <!-- Footer Partial -->
      <%- include("../../views/partials/admin/footer")%>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <!-- JavaScript -->
        <script>

          // Search form reset
          const searchForm = document.getElementById('searchForm');
          if (searchForm) {
            searchForm.addEventListener('submit', function () {
              const pageInput = this.querySelector('input[name="page"]');
              if (pageInput) {
                pageInput.value = '1';
              }
            });
          }

        </script>
        <script>
          document.getElementById('editCategoryModal')
            .addEventListener('show.bs.modal', function (event) {

              const btn = event.relatedTarget;

              document.getElementById('editCategoryId').value = btn.dataset.id;
              document.getElementById('editCategoryName').value = btn.dataset.name;
              document.getElementById('editCategoryDescription').value = btn.dataset.description;
              document.getElementById('editPreviewImage').src = btn.dataset.image;

              if (btn.dataset.listed === "true") {
                document.getElementById('editListed').checked = true;
              } else {
                document.getElementById('editUnlisted').checked = true;
              }
            });
        </script>

        <script>
          const success = "<%= success || '' %>";
          const error = "<%= error || '' %>";

          if (success === 'added') {
            Swal.fire('Success', 'Category added successfully', 'success');
          }

          if (error === 'failed') {
            Swal.fire('Error', 'Failed to add category', 'error');
          }

          if (success === 'updated') {
            Swal.fire('Success', 'Category updated successfully', 'success');
          }

          if (error === 'edit_failed') {
            Swal.fire('Error', 'Failed to update category', 'error');
          }

          if (success === 'listed') {
            Swal.fire('Success', 'Category listed successfully', 'success');
          }

          if (success === 'unlisted') {
            Swal.fire('Success', 'Category unlisted successfully', 'success');
          }

          if (error === 'list_failed') {
            Swal.fire('Error', 'Failed to list category', 'error');
          }

          if (error === 'unlist_failed') {
            Swal.fire('Error', 'Failed to unlist category', 'error');
          }

          if (error === 'exists') {
            Swal.fire('Error', 'category already exist', 'error');
          }


        </script>
        <script>
          const addCategoryForm = document.getElementById('addCategoryForm');
          const editCategoryForm = document.getElementById('editCategoryForm');

          const nameInput = document.getElementById('categoryName');
          const imageInput = document.getElementById('categoryImage');
          const editNameInput = document.getElementById('editCategoryName');

          const nameError = document.getElementById('nameError');
          const imageError = document.getElementById('imageError');
          const editNameError = document.getElementById('editNameError');
          const editImageError = document.getElementById('editImageError');

          const clearInlineErrors = () => {
            if (nameError) nameError.textContent = '';
            if (imageError) imageError.textContent = '';
            if (editNameError) editNameError.textContent = '';
            if (editImageError) editImageError.textContent = '';
          };

          const validateAddForm = () => {
            clearInlineErrors();
            let valid = true;

            if (!nameInput.value.trim()) {
              nameError.textContent = 'Category name is required.';
              valid = false;
            }

            if (!imageInput.files.length) {
              imageError.textContent = 'Category image is required.';
              valid = false;
            }

            return valid;
          };

          const validateEditForm = () => {
            clearInlineErrors();
            let valid = true;

            if (editNameInput && !editNameInput.value.trim()) {
              editNameError.textContent = 'Category name is required.';
              valid = false;
            }

            return valid;
          };

          if (addCategoryForm) {
            addCategoryForm.addEventListener('submit', (event) => {
              if (!validateAddForm()) {
                event.preventDefault();
              }
            });
          }

          if (editCategoryForm) {
            editCategoryForm.addEventListener('submit', (event) => {
              if (!validateEditForm()) {
                event.preventDefault();
              }
            });
          }
        </script>
<script>

const offerForm = document.getElementById("offerForm")

let editMode = false

// =========================
// ADD OFFER BUTTON
// =========================
document.querySelectorAll('[data-offer-type="add"]').forEach(btn => {

  btn.addEventListener("click", () => {

    editMode = false

    const categoryId = btn.dataset.categoryId

    document.getElementById("offerCategoryId").value = categoryId

    offerForm.reset()

  })

})


// =========================
// EDIT OFFER BUTTON
// =========================
document.querySelectorAll(".editOfferBtn").forEach(btn => {

  btn.addEventListener("click", async () => {

    editMode = true

    const categoryId = btn.dataset.categoryId

    try{

      const res = await fetch(`/admin/category/offer/${categoryId}`)

      const data = await res.json()

      if(data.success){

        const offer = data.offer

        document.getElementById("offerCategoryId").value = categoryId
        document.getElementById("offerTitle").value = offer.offerTitle
        document.getElementById("discountType").value = offer.discountType
        document.getElementById("discountValue").value = offer.discountValue
        document.getElementById("startDate").value = offer.startDate.split("T")[0]
        document.getElementById("endDate").value = offer.endDate.split("T")[0]

        new bootstrap.Modal(document.getElementById("offerModal")).show()

      }

    }catch(err){
      console.error(err)
    }

  })

})


// =========================
// REMOVE OFFER BUTTON
// =========================
document.querySelectorAll(".removeOfferBtn").forEach(btn => {

  btn.addEventListener("click", async () => {

    const categoryId = btn.dataset.categoryId

    const confirm = await Swal.fire({
      title:"Remove Offer?",
      text:"This action cannot be undone",
      icon:"warning",
      showCancelButton:true
    })

    if(!confirm.isConfirmed) return

    try{

      const res = await fetch(`/admin/category/offer/remove/${categoryId}`,{
        method:"DELETE"
      })

      const data = await res.json()

      if(data.success){

        Swal.fire("Success","Offer removed successfully","success")
        setTimeout(()=>location.reload(),1200)

      }

    }catch(err){

      Swal.fire("Error","Failed to remove offer","error")

    }

  })

})


// =========================
// CLIENT VALIDATION
// =========================
function clearOfferErrors(){

  document.getElementById("offerTitleError").textContent = ""
  document.getElementById("discountTypeError").textContent = ""
  document.getElementById("discountValueError").textContent = ""
  document.getElementById("startDateError").textContent = ""
  document.getElementById("endDateError").textContent = ""

}

function validateOffer(){

  clearOfferErrors()

  let valid = true

  const title = document.getElementById("offerTitle").value.trim()
  const discountType = document.getElementById("discountType").value
  const discountValue = document.getElementById("discountValue").value
  const startDate = document.getElementById("startDate").value
  const endDate = document.getElementById("endDate").value

  if(!title){

    document.getElementById("offerTitleError").textContent = "Offer title is required"
    valid = false

  }

  if(!discountType){

    document.getElementById("discountTypeError").textContent = "Select discount type"
    valid = false

  }

  if(!discountValue || discountValue <= 0){

    document.getElementById("discountValueError").textContent = "Discount must be greater than 0"
    valid = false

  }

  if(discountType === "percentage" && discountValue > 90){

    document.getElementById("discountValueError").textContent = "Percentage cannot exceed 90%"
    valid = false

  }

  if(!startDate){

    document.getElementById("startDateError").textContent = "Start date required"
    valid = false

  }

  if(!endDate){

    document.getElementById("endDateError").textContent = "End date required"
    valid = false

  }

  if(startDate && endDate && new Date(startDate) >= new Date(endDate)){

    document.getElementById("endDateError").textContent = "End date must be after start date"
    valid = false

  }

  return valid

}

// =========================
// SUBMIT OFFER
// =========================
offerForm.addEventListener("submit", async function(e){

  e.preventDefault()

  if(!validateOffer()) return

  const categoryId = document.getElementById("offerCategoryId").value

  const body = {

    categoryId,
    offerTitle: document.getElementById("offerTitle").value,
    discountType: document.getElementById("discountType").value,
    discountValue: document.getElementById("discountValue").value,
    startDate: document.getElementById("startDate").value,
    endDate: document.getElementById("endDate").value

  }

  try{

    let url = "/admin/category/offer/add"
    let method = "POST"

    if(editMode){

      url = "/admin/category/offer/edit"
      method = "PUT"

    }

    const res = await fetch(url,{
      method,
      headers:{
        "Content-Type":"application/json"
      },
      body:JSON.stringify(body)
    })

    const data = await res.json()

    if(data.success){

      Swal.fire("Success","Offer saved successfully","success")

      setTimeout(()=>location.reload(),1200)

    }else{

      Swal.fire("Error",data.message || "Something went wrong","error")

    }

  }catch(err){

    Swal.fire("Error","Server error","error")

  }

})

</script>
</body>

</html>