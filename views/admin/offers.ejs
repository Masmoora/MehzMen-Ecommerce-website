<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Offers</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
 body { background: #f5f7fb; padding-top: 70px; padding-left: 260px; min-height: 100vh; display: flex; flex-direction: column; }
    .main-content { flex: 1; padding: 2rem; margin-bottom: 80px; }
  </style>
</head>
<body>
<%- include("../partials/admin/header") %>
<%- include("../partials/admin/sidebar") %>

  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="mb-0">Offer Management</h2>
      <button type="button" class="btn btn-success" onclick="openAddOfferModal()">
        <i class="bi bi-plus-circle me-1"></i> Add Offer
      </button>
    </div>

    <form class="row g-2 mb-3" method="GET" action="/admin/offers">
      <div class="col-md-4">
        <input type="text" class="form-control" name="search" placeholder="Search here" value="<%= search %>">
      </div>
      <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-primary w-100" type="submit">Search</button>
        <a href="/admin/offers" class="btn btn-outline-secondary w-100">Clear</a>
      </div>
    </form>

    <div class="table-responsive bg-white border rounded">
      <table class="table table-bordered table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>DiscountType</th>
            <th>DiscountValue</th>
            <th>StartDate</th>
            <th>EndDate</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!offers || offers.length === 0) { %>
            <tr><td colspan="8" class="text-center py-3">No offers found</td></tr>
          <% } else { %>
            <% offers.forEach(offer => { %>
              <tr>
                <td><%= offer.name %></td>
                <td><%= offer.type %></td>
                <td><%= offer.discountType %></td>
                <td><%= offer.discountValue %></td>
                <td><%= new Date(offer.startDate).toLocaleDateString("en-IN") %></td>
                <td><%= new Date(offer.endDate).toLocaleDateString("en-IN") %></td>
                <td>
                  <span class="badge <%= offer.isActive ? 'bg-success' : 'bg-secondary' %>">
                    <%= offer.isActive ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td>
                  <button type="button" data-offer='<%- JSON.stringify(offer) %>' class="editBtn btn btn-sm btn-warning mb-1">Edit</button>
                  <button type="button" onclick="deactivateOffer('<%= offer._id %>')" class="btn btn-sm btn-danger mb-1">Deactivate</button>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="offerModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header bg-dark text-white">
            <h5 class="modal-title" id="modalTitle">Add Offers</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <form id="modalForm">
            <div class="modal-body">
              <input type="hidden" id="offerId" name="offerId">
              <input type="hidden" id="mode" name="mode" value="add">
              <div class="row g-2 mb-2">
                <div class="col-md-6">
                  <label for="name" class="form-label">Offer Name</label>
                  <input type="text" class="form-control" id="name" name="name" placeholder="Enter offer name">
                </div>
                <div class="col-md-6">
                  <label for="type" class="form-label">Offer Type</label>
                  <select id="type" name="type" class="form-select" required>
                    <option value="">Select</option>
                    <option value="PRODUCT">Product</option>
                    <option value="CATEGORY">Category</option>
                  </select>
                </div>
              </div>
              <div id="productField" class="mb-2 d-none">
                <label for="productId" class="form-label">Product</label>
                <select id="productId" class="form-select">
                  <option value="">Select Product</option>
                  <% if (products && products.length) { %>
                    <% products.forEach(p => { %>
                      <option value="<%= p._id %>"><%= p.name %></option>
                    <% }); %>
                  <% } %>
                </select>
              </div>
              <div id="categoryField" class="mb-2 d-none">
                <label for="categoryId" class="form-label">Category</label>
                <select id="categoryId" class="form-select">
                  <option value="">Select Category</option>
                  <% if (categories && categories.length) { %>
                    <% categories.forEach(c => { %>
                      <option value="<%= c._id %>"><%= c.name %></option>
                    <% }); %>
                  <% } %>
                </select>
              </div>
              <div class="mb-2">
                <label for="discountType" class="form-label">Discount Type</label>
                <select id="discountType" name="discountType" class="form-select" required>
                  <option value="">Select</option>
                  <option value="PERCENTAGE">Percentage</option>
                  <option value="FLAT">Fixed</option>
                </select>
              </div>
              <div class="mb-2">
                <label for="discountValue" class="form-label">Discount Value</label>
                <input type="number" class="form-control" id="discountValue" name="discountValue" min="0">
              </div>
              <div class="row g-2 mb-2">
                <div class="col-md-6">
                  <label for="startDate" class="form-label">Start Date</label>
                  <input type="date" class="form-control" id="startDate" name="startDate">
                </div>
                <div class="col-md-6">
                  <label for="endDate" class="form-label">End Date</label>
                  <input type="date" class="form-control" id="endDate" name="endDate" required>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" id="submitBtn" class="btn btn-dark">Create</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <% if (totalPages && totalPages > 1) { %>
      <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
          <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="/admin/offers?page=<%= page - 1 %>&search=<%= search %>">Prev</a>
          </li>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= page === i ? 'active' : '' %>">
              <a class="page-link" href="/admin/offers?page=<%= i %>&search=<%= search %>"><%= i %></a>
            </li>
          <% } %>
          <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="/admin/offers?page=<%= page + 1 %>&search=<%= search %>">Next</a>
          </li>
        </ul>
      </nav>
    <% } %>
  </main>


<%- include("../partials/admin/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let offerModalEl = null;
    function getModal() {
      if (!offerModalEl) offerModalEl = new bootstrap.Modal(document.getElementById('offerModal'));
      return offerModalEl;
    }
    function openAddOfferModal() {
      document.getElementById('modalTitle').innerText = 'Add Offers';
      document.getElementById('submitBtn').innerText = 'Create';
      document.getElementById('mode').value = 'add';
      document.getElementById('modalForm').reset();
      document.getElementById('offerId').value = '';
      document.getElementById('type').disabled = false;
      document.getElementById('discountType').disabled = false;
      document.getElementById('productField').classList.add('d-none');
      document.getElementById('categoryField').classList.add('d-none');
      getModal().show();
    }
    document.querySelectorAll('.editBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        const offer = JSON.parse(btn.dataset.offer);
        openEditOfferModal(offer);
      });
    });
    function openEditOfferModal(offer) {
      document.getElementById('modalTitle').innerText = 'Edit offer';
      document.getElementById('submitBtn').innerText = 'Update';
      document.getElementById('mode').value = 'edit';
      document.getElementById('offerId').value = offer._id;
      document.getElementById('name').value = offer.name;
      document.getElementById('discountValue').value = offer.discountValue;
      document.getElementById('startDate').value = new Date(offer.startDate).toISOString().split('T')[0];
      document.getElementById('endDate').value = new Date(offer.endDate).toISOString().split('T')[0];
      const typeEl = document.getElementById('type');
      const discountTypeEl = document.getElementById('discountType');
      typeEl.value = offer.type;
      discountTypeEl.value = offer.discountType;
      typeEl.disabled = true;
      discountTypeEl.disabled = true;
      document.getElementById('productField').classList.add('d-none');
      document.getElementById('categoryField').classList.add('d-none');
      if (offer.type === 'PRODUCT') {
        document.getElementById('productField').classList.remove('d-none');
        document.getElementById('productId').value = offer.productId ? offer.productId.toString() : '';
      }
      if (offer.type === 'CATEGORY') {
        document.getElementById('categoryField').classList.remove('d-none');
        document.getElementById('categoryId').value = offer.categoryId ? offer.categoryId.toString() : '';
      }
      getModal().show();
    }
    const typeEl = document.getElementById('type');
    const productField = document.getElementById('productField');
    const categoryField = document.getElementById('categoryField');
    typeEl.addEventListener('change', () => {
      productField.classList.add('d-none');
      categoryField.classList.add('d-none');
      if (typeEl.value === 'PRODUCT') productField.classList.remove('d-none');
      if (typeEl.value === 'CATEGORY') categoryField.classList.remove('d-none');
    });
    document.getElementById('modalForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const mode = document.getElementById('mode').value;
      const offerId = document.getElementById('offerId').value;
      const type = document.getElementById('type').value;
      const payload = {
        name: document.getElementById('name').value.trim(),
        discountValue: Number(document.getElementById('discountValue').value),
        startDate: document.getElementById('startDate').value,
        endDate: document.getElementById('endDate').value
      };
      if (mode === 'add') {
        payload.type = document.getElementById('type').value;
        payload.discountType = document.getElementById('discountType').value;
      }
      if (type === 'PRODUCT') payload.productId = document.getElementById('productId').value;
      if (type === 'CATEGORY') payload.categoryId = document.getElementById('categoryId').value;
      const url = mode === 'add' ? '/admin/offers/add' : '/admin/offers/edit/' + offerId;
      const method = mode === 'add' ? 'POST' : 'PUT';
      const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json();
      if (!res.ok) return Swal.fire({ icon: 'error', title: data.message || 'Error' });
      await Swal.fire({ icon: 'success', title: data.message });
      location.reload();
    });
    async function deactivateOffer(id) {
      const result = await Swal.fire({
        title: 'Deactivate this offer?',
        text: 'This offer will no longer be applied to users.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, deactivate',
        cancelButtonText: 'Cancel',
        confirmButtonColor: '#d33'
      });
      if (!result.isConfirmed) return;
      try {
        const res = await fetch('/admin/offers/deactivate/' + id, { method: 'PATCH' });
        const data = await res.json();
        if (!res.ok) return Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
        await Swal.fire({ icon: 'success', title: 'Deactivated', text: 'Offer deactivated successfully', timer: 1500, showConfirmButton: false });
        location.reload();
      } catch (err) {
        Swal.fire({ icon: 'error', title: 'Server Error', text: 'Something went wrong' });
      }
    }
  </script>
</body>
</html>

