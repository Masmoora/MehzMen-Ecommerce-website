<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Management - MehzMen Admin</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin/product.css">
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

      <!-- Main Content -->
      <main class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="page-title mb-0">Product Management</h1>
          <a href="/admin/addProducts" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>Add Product
          </a>
        </div>

        <!-- Search & Filter Section -->
        <div class="search-section">
          <form action="/admin/products" method="GET" class="search-form" id="searchForm">
            <div class="search-input-group">
              <label for="searchInput" class="form-label">Search Products</label>
              <input type="text" class="form-control" id="searchInput" name="search"
                placeholder="Search by product name" value="<%= typeof search !== 'undefined' ? search : '' %>">
              <input type="hidden" name="page" value="1">
            </div>
            <div class="search-input-group">
              <label for="brandFilter" class="form-label">Brand</label>
              <select class="form-select" id="brandFilter" name="brand">
                <option value="">All Brands</option>
                <% if (typeof brands !=='undefined' && brands.length> 0) { %>
                  <% brands.forEach(br=> { %>
                    <option value="<%= br._id %>" <%=(brand===br._id.toString()) ? 'selected' : '' %>>
                      <%= br.name %>
                    </option>
                    <% }) %>

                      <% } %>
              </select>
            </div>
            <div class="search-input-group">
              <label for="categoryFilter" class="form-label">Category</label>
              <select class="form-select" id="categoryFilter" name="category">
                <option value="">All Categories</option>
                <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                  <% categories.forEach(cat=> { %>
                    <option value="<%= cat._id %>" <%=(category===cat._id.toString()) ? 'selected' : '' %>>
                      <%= cat.name %>
                    </option>
                    <% }) %>

                      <% } %>
              </select>
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Search
              </button>
              <a href="/admin/products" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Clear
              </a>
            </div>
          </form>
        </div>

        <!-- Product Table -->
        <div class="table-container">
          <% if (typeof products !=='undefined' && products.length> 0) { %>
            <table class="table table-hover">
              <thead>
                <tr>

                  <th>Product Name</th>
                  <th>Brand</th>
                  <th>Category</th>
                  <th>Offer Price</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% products.forEach(product=> { %>
                  <tr>
                    <td class="fw-semibold">
                      <%= product.name %>
                    </td>
                    <td>
                      <%= product.brand ? product.brand.name : 'N/A' %>
                    </td>
                    <td>
                      <%= product.category ? product.category.name : 'N/A' %>
                    </td>

                    <td>
                      <% if (product.offerPrice) { %>
                        <span class="text-success fw-bold">₹<%= product.offerPrice %></span>
                        <% } else { %>
                          <span class="text-muted">-</span>
                          <% } %>
                    </td>
                    <td>
                      <% if (product.isBlocked) { %>
                        <span class="badge bg-danger">
                          <i class="bi bi-x-circle me-1"></i>Blocked
                        </span>
                        <% } else { %>
                          <span class="badge bg-success">
                            <i class="bi bi-check-circle me-1"></i>Active
                          </span>
                          <% } %>
                    </td>

                    <td>
                      <a href="/admin/products/<%= product._id %>/variants" class="btn btn-sm btn-info">
                        View / Add Variants
                      </a>
                    </td>

                    <td>
                      <div class="d-flex gap-1 flex-wrap">
                        <a href="/admin/products/<%= product._id %>/edit" class="btn btn-sm btn-primary btn-action">
                          <i class="bi bi-pencil-square me-1"></i>Edit
                        </a>
                        <button class="btn btn-sm btn-info btn-action toggle-block-btn" data-id="<%= product._id %>"
                          data-blocked="<%= product.isBlocked %>">
                          <i class="bi bi-<%= product.isBlocked ? 'unlock' : 'lock' %> me-1"></i>
                          <%= product.isBlocked ? 'Unblock' : 'Block' %>
                        </button>



                        <% if(product.hasOffer){ %>

                          <button class="btn btn-warning btn-sm" onclick="openOfferModal('<%= product._id %>')">
                            Edit Offer
                          </button>

                          <button class="btn btn-danger btn-sm" onclick="removeOffer('<%= product._id %>')">
                            Remove Offer
                          </button>

                          <% } else { %>

                            <button class="btn btn-success btn-sm" onclick="openOfferModal('<%= product._id %>')">
                              Add Offer
                            </button>

                            <% } %>



                      </div>
                    </td>
                  </tr>
                  <% }); %>
              </tbody>
            </table>
            <% } else { %>
              <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h5>No products found</h5>
                <p class="text-muted">
                  <% if (typeof search !=='undefined' && search) { %>
                    No products match your search criteria.
                    <% } else { %>
                      There are no products yet.
                      <% } %>
                </p>
              </div>
              <% } %>
        </div>

        <!-- Pagination -->
        <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
          <div class="d-flex justify-content-end me-5 mt-5">
            <nav>
              <ul class="pagination">
                <% if (page> 1) { %>
                  <li class="page-item">
                    <a class="page-link"
                      href="?page=<%= page - 1 %>&search=<%= typeof search !== 'undefined' ? encodeURIComponent(search) : '' %>&brand=<%= typeof brand !== 'undefined' ? brand : '' %>&category=<%= typeof category !== 'undefined' ? category : '' %>">Prev</a>
                  </li>
                  <% } %>

                    <% for (let i=1; i <=totalPages; i++) { %>
                      <li class="page-item <%= page === i ? 'active' : '' %>">
                        <a class="page-link"
                          href="?page=<%= i %>&search=<%= typeof search !== 'undefined' ? encodeURIComponent(search) : '' %>&brand=<%= typeof brand !== 'undefined' ? brand : '' %>&category=<%= typeof category !== 'undefined' ? category : '' %>">
                          <%= i %>
                        </a>
                      </li>
                      <% } %>

                        <% if (page < totalPages) { %>
                          <li class="page-item">
                            <a class="page-link"
                              href="?page=<%= page + 1 %>&search=<%= typeof search !== 'undefined' ? encodeURIComponent(search) : '' %>&brand=<%= typeof brand !== 'undefined' ? brand : '' %>&category=<%= typeof category !== 'undefined' ? category : '' %>">Next</a>
                          </li>
                          <% } %>
              </ul>
            </nav>
          </div>
          <% } %>
      </main>

      <!-- Offer Modal -->
      <div class="modal fade" id="offerModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">

            <div class="modal-header">
              <h5 class="modal-title" id="offerModalTitle">Add Product Offer</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

              <form id="offerForm">

                <input type="hidden" id="productId">

                <div class="mb-3">
                  <label class="form-label">Offer Title</label>
                  <input type="text" id="offerTitle" class="form-control">
                  <small class="text-danger" id="titleError"></small>
                </div>

                <div class="mb-3">
                  <label class="form-label">Discount Type</label>
                  <select id="discountType" class="form-control">
                    <option value="">Select</option>
                    <option value="percentage">Percentage</option>
                    <option value="fixed">Fixed</option>
                  </select>
                  <small class="text-danger" id="typeError"></small>
                </div>

                <div class="mb-3">
                  <label class="form-label">Discount Value</label>
                  <input type="number" id="discountValue" class="form-control">
                  <small class="text-danger" id="valueError"></small>
                </div>

                <div class="mb-3">
                  <label class="form-label">Start Date</label>
                  <input type="date" id="startDate" class="form-control">
                  <small class="text-danger" id="startError"></small>
                </div>

                <div class="mb-3">
                  <label class="form-label">End Date</label>
                  <input type="date" id="endDate" class="form-control">
                  <small class="text-danger" id="endError"></small>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                  Save Offer
                </button>

              </form>

            </div>
          </div>
        </div>
      </div>

      <!-- Footer Partial -->
      <%- include("../../views/partials/admin/footer")%>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <script>
          // Block/Unblock product
          document.querySelectorAll('.toggle-block-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
              const productId = this.dataset.id;
              const isBlocked = this.dataset.blocked === 'true';

              const result = await Swal.fire({
                title: isBlocked ? 'Unblock Product?' : 'Block Product?',
                text: `Are you sure you want to ${isBlocked ? 'unblock' : 'block'} this product?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: isBlocked ? '#28a745' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, do it!'
              });

              if (result.isConfirmed) {
                try {
                  const res = await fetch(`/admin/products/${productId}/block`, {
                    method: 'PATCH'
                  });
                  const data = await res.json();

                  if (res.ok) {
                    Swal.fire('Success', data.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                  } else {
                    Swal.fire('Error', data.message || 'Failed to update product', 'error');
                  }
                } catch (error) {
                  Swal.fire('Error', 'Something went wrong', 'error');
                }
              }
            });
          });
        </script>
        <script>
          let isEdit =false

                      document.getElementById("offerForm").addEventListener("submit", async function (e) {

              e.preventDefault()

              clearErrors()

              const productId = document.getElementById("productId").value
              const title = document.getElementById("offerTitle").value.trim()
              const type = document.getElementById("discountType").value
              const value = document.getElementById("discountValue").value
              const startDate = document.getElementById("startDate").value
              const endDate = document.getElementById("endDate").value

              let valid = true

              if (!title) {
                document.getElementById("titleError").innerText = "Offer title required"
                valid = false
              }

              if (!type) {
                document.getElementById("typeError").innerText = "Select discount type"
                valid = false
              }

              if (!value || value <= 0) {
                document.getElementById("valueError").innerText = "Enter valid value"
                valid = false
              }

              if (type === "percentage" && value > 90) {
                document.getElementById("valueError").innerText = "Max percentage 90%"
                valid = false
              }

              if (!startDate) {
                document.getElementById("startError").innerText = "Start date required"
                valid = false
              }

              if (!endDate) {
                document.getElementById("endError").innerText = "End date required"
                valid = false
              }

              if (new Date(startDate) >= new Date(endDate)) {
                document.getElementById("endError").innerText = "End date must be after start date"
                valid = false
              }

              if (!valid) return

              try {

                const res = await fetch(`/admin/products/${productId}/offer`, {

                  method: isEdit ? "PUT":"POST",

                  headers: {
                    "Content-Type": "application/json"
                  },

                  body: JSON.stringify({
                    offerTitle: title,
                    discountType: type,
                    discountValue: value,
                    startDate,
                    endDate
                  })

                })

                const data = await res.json()

                if (res.ok) {

                  Swal.fire("Success", data.message, "success")

                  bootstrap.Modal.getInstance(document.getElementById("offerModal")).hide()

                  setTimeout(() => location.reload(), 1000)

                } else {

                  Swal.fire("Error", data.message, "error")

                }

              } catch (err) {

                Swal.fire("Error", "Something went wrong", "error")

              }

            })
          // Open Offer Modal
          async function openOfferModal(productId) {

            document.getElementById("productId").value = productId

            // Clear errors
            clearErrors()

            try {

              const res = await fetch(`/admin/products/${productId}/offer`)
              const data = await res.json()

              if (data.offer) {
                isEdit =true

                document.getElementById("offerModalTitle").innerText = "Edit Product Offer"

                document.getElementById("offerTitle").value = data.offer.offerTitle
                document.getElementById("discountType").value = data.offer.discountType
                document.getElementById("discountValue").value = data.offer.discountValue
                document.getElementById("startDate").value = data.offer.startDate.split("T")[0]
                document.getElementById("endDate").value = data.offer.endDate.split("T")[0]

              } else {
                isEdit = false

                document.getElementById("offerModalTitle").innerText = "Add Product Offer"

                document.getElementById("offerTitle").value = ""
                document.getElementById("discountType").value = ""
                document.getElementById("discountValue").value = ""
                document.getElementById("startDate").value = ""
                document.getElementById("endDate").value = ""

              }

              new bootstrap.Modal(document.getElementById("offerModal")).show()

            } catch (err) {

              Swal.fire("Error", "Failed to load offer", "error")

            }


          }

          async function removeOffer(productId) {

            const confirm = await Swal.fire({
              title: "Remove Offer?",
              icon: "warning",
              showCancelButton: true
            })

            if (!confirm.isConfirmed) return

            const res = await fetch(`/admin/products/${productId}/offer`, {
              method: "DELETE"
            })

            const data = await res.json()

            if (res.ok) {

              Swal.fire("Success", data.message, "success")

              setTimeout(() => location.reload(), 1000)

            } else {

              Swal.fire("Error", data.message, "error")

            }

          }
          function clearErrors() {

            document.getElementById("titleError").innerText = ""
            document.getElementById("typeError").innerText = ""
            document.getElementById("valueError").innerText = ""
            document.getElementById("startError").innerText = ""
            document.getElementById("endError").innerText = ""

          }
        </script>




</body>

</html>