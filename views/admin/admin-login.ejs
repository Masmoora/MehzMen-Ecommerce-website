<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Login | MehzMen</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin/adminLogin.css">
</head>

<body>

    <div class="login-card">

        <div class="logo-text">MehzMen</div>
        <%if(typeof message!=='undefined' && message){%>
            <div class="alert alert-danger text-center">
                <%=message%>
            </div>
            <%}%>

                <!-- Admin Login Form -->
                <form action="/admin/login" method="POST">

                    <!-- Email -->
                    <div class="mb-3">
                        <input type="email" name="email" class="form-control" placeholder="Email Address" required>
                    </div>

                    <!-- Password -->
                    <div class="mb-2 password-box">
                        <input type="password" name="password" id="passwordField" class="form-control"
                            placeholder="Password" required>
                        <span class="toggle-icon" onclick="togglePassword()">
                            👁️
                        </span>
                    </div>

                    <a href="#" class="forgot-link">Forgot Password?</a>

                    <!-- Login Button -->
                    <button type="submit" class="btn btn-login">Login</button>

                </form>

    </div>

    <script>
        function togglePassword() {
            const pass = document.getElementById("passwordField");
            pass.type = pass.type === "password" ? "text" : "password";
        }
    </script>

</body>

</html>