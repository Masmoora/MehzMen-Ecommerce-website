<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Coupon Management - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/admin/adminCoupon.css">

</head>

<body>
  <!-- Header Partial -->
  <%- include("../../views/partials/admin/header")%>

    <!-- Sidebar Partial -->
    <%- include("../../views/partials/admin/sidebar")%>

      <main class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-3">
          
          <h1 class="page-title" mb-0>Coupon Management</h1>
          <a href="/admin/coupons/add" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i> Add New Coupon
          </a>
        </div>

        <form class="row g-2 mb-3" method="GET" action="/admin/coupons">
          <div class="col-md-4">
            <input type="text" class="form-control" name="search" placeholder="Search by coupon code"
              value="<%= search || '' %>" />
          </div>
          <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100" type="submit">Search</button>
            <a href="/admin/coupons" class="btn btn-outline-secondary w-100">Clear</a>
          </div>
        </form>

        <div class="table-responsive bg-white border rounded">
          <table class="table table-bordered table-striped mb-0">
            <thead class="table-dark">
              <tr>
                <th>Code</th>
                <th>Type</th>
                <th>Value</th>
                <th>Min Order</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>Used / Limit</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!coupons || coupons.length===0) { %>
                <tr>
                  <td colspan="10" class="text-center py-3">No coupons available</td>
                </tr>
                <% } else { %>
                  <% coupons.forEach((coupon)=> { %>
                    <tr>
                      <td>
                        <%= coupon.code %>
                      </td>
                      <td class="text-capitalize">
                        <%= coupon.type %>
                      </td>
                      <td>
                        <% if (coupon.type==='percentage' ) { %>
                          <%= coupon.value %>%
                            <% } else { %>
                              ₹<%= coupon.value %>
                                <% } %>
                      </td>
                      <td>₹<%= coupon.minOrderValue || 0 %>
                      </td>

                      <td>
                        <%= coupon.startDate ? new Date(coupon.startDate).toLocaleDateString() : '-' %>
                      </td>
                      <td>
                        <%= coupon.endDate ? new Date(coupon.endDate).toLocaleDateString() : '-' %>
                      </td>
                      <td>
                        <span class="badge <%= coupon.isActive ? 'bg-success' : 'bg-secondary' %>">
                          <%= coupon.isActive ? 'Active' : 'Inactive' %>
                        </span>
                      </td>
                      <td>
                        <%= coupon.usedCount || 0 %> /
                          <%= coupon.usageLimit !=null ? coupon.usageLimit : '∞' %>
                      </td>
                      <td>
                        <a href="/admin/coupons/edit/<%= coupon._id %>" class="btn btn-sm btn-warning mb-1">
                          Edit
                        </a>
                        <button type="button" class="btn btn-sm btn-danger mb-1"
                          onclick="deleteCoupon('<%= coupon._id %>')">
                          Delete
                        </button>
                      </td>
                    </tr>
                    <% }) %>
                      <% } %>
            </tbody>
          </table>
        </div>

        <% if (totalPages && totalPages> 1) { %>
          <nav class="mt-3">
            <ul class="pagination justify-content-center">
              <% for (let i=1; i <=totalPages; i++) { %>
                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                  <a class="page-link" href="/admin/coupons?page=<%= i %>&search=<%= search || '' %>">
                    <%= i %>
                  </a>
                </li>
                <% } %>
            </ul>
          </nav>
          <% } %>
      </main>

      <%- include("../../views/partials/admin/footer")%>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
          async function deleteCoupon(couponId) {
            const confirmDelete = await Swal.fire({
              icon: 'warning',
              title: 'Delete coupon?',
              text: 'Are you sure you want to delete this coupon?',
              showCancelButton: true,
              confirmButtonText: 'Yes, delete',
              cancelButtonText: 'Cancel'
            });
            if (!confirmDelete.isConfirmed) return;

            try {
              const response = await fetch(`/admin/coupons/delete/${couponId}`, {
                method: 'DELETE'
              });
              const result = await response.json();
              if (response.ok && result.success) {
                await Swal.fire('Deleted', result.message || 'Coupon deleted', 'success');
                location.reload();
              } else {
                Swal.fire('Oops', result.message || 'Something went wrong', 'warning');
              }
            } catch (error) {
              console.error('Error while deleting coupon', error);
              Swal.fire('Error', error.message || 'Internal server error', 'error');
            }
          }
        </script>
</body>

</html>