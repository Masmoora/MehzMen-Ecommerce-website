<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Email</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="/css/user/change-Email.css">

</head>

<body>
  <%- include("../partials/user/header") %>

    <% const currentEmail=(user && user.email) ? user.email : '' ; const newEmailValue=(formData && formData.newEmail) ?
      formData.newEmail : '' ; const alertType=alert || '' ; %>

      <main class="container py-5">
        <div class="row justify-content-center">
          <div class="col-md-6">
            <div class="card card-soft p-4">
              <h4 class="mb-4 text-center">Change Email</h4>

              <form action="/change-email" method="POST" id="changeEmailForm">
                <div class="mb-3">
                  <label class="form-label">Current Email</label>
                  <input type="email" class="form-control" value="<%= currentEmail %>" readonly>
                </div>

                <div class="mb-3">
                  <label class="form-label">New Email</label>
                  <input type="email" name="newEmail" id="newEmail" class="form-control" value="<%= newEmailValue %>">
                  <div class="error-text" id="newEmailError"></div>
                </div>

                <div class="mb-3">
                  <label class="form-label">Current Password</label>
                  <input type="password" name="password" id="password" class="form-control">
                  <div class="error-text" id="passwordError"></div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Send OTP</button>
              </form>

              <div class="mt-3 text-center">
                <a href="/userProfile" class="text-muted">← Back to Profile</a>
              </div>
            </div>
          </div>
        </div>
      </main>

      <%- include("../partials/user/footer") %>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script>
          const changeEmailForm = document.getElementById('changeEmailForm');
          const newEmailInput = document.getElementById('newEmail');
          const passwordInput = document.getElementById('password');
          const newEmailError = document.getElementById('newEmailError');
          const passwordError = document.getElementById('passwordError');

          changeEmailForm.addEventListener('submit', (event) => {
            let isValid = true;
            const emailValue = newEmailInput.value.trim();
            const passwordValue = passwordInput.value.trim();
            const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            newEmailError.textContent = '';
            passwordError.textContent = '';

            if (!emailValue) {
              newEmailError.textContent = 'New email is required';
              isValid = false;
            } else if (!emailPattern.test(emailValue)) {
              newEmailError.textContent = 'Enter a valid email address';
              isValid = false;
            }

            if (!passwordValue) {
              passwordError.textContent = 'Password is required';
              isValid = false;
            }

            if (!isValid) {
              event.preventDefault();
            }
          });

          const alertType = '<%= alertType %>';
          if (alertType) {
            const messages = {
              required: 'All fields are required',
              'invalid-email': 'Enter a valid email address',
              'same-email': 'New email must be different',
              'email-exists': 'Email is already in use',
              'invalid-password': 'Current password is incorrect',
              'send-failed': 'Failed to send OTP. Try again',
              'server-error': 'Something went wrong. Try again'
            };
            Swal.fire({
              icon: 'error',
              title: 'Oops',
              text: messages[alertType] || 'Something went wrong'
            });
          }
        </script>
</body>

</html>