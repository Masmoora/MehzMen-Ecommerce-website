<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/user/userProfile.css">

</head>

<body>
  <%- include("../partials/user/header") %>

    <% const profileImage=(user && (user.profileImage || user.avatar)) || 'https://via.placeholder.com/140' ; const
      fullName=(user && user.name) ? user.name : '-' ; const email=(user && user.email) ? user.email : '-' ; const
      phone=(user && user.phone) ? user.phone : '-' ; const successMessage=success==='profile-updated'
      ? 'Profile updated successfully' : success==='email-updated' ? 'Email updated successfully' : '' ; %>

      <main class="container py-4">
        <div class="row g-4">
          <div class="col-12 col-lg-3">
            <%- include("../partials/user/profileSidebar", { user, activeItem: "account" }) %>
          </div>
          <div class="col-12 col-lg-9">
            <div class="card card-soft p-4">
              <% if (successMessage) { %>
                <div class="alert alert-success" role="alert">
                  <%= successMessage %>
                </div>
                <% } %>
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h4 class="mb-0">My Profile</h4>
                    <a href="/edit-userProfile" class="btn btn-dark">
                      <i class="bi bi-pencil-square me-1"></i>Edit Profile
                    </a>
                  </div>

                  <div class="text-center mb-4">
                    <img 
  src="<%= profileImage %>" 
  alt="Profile" 
  class="rounded-circle profile-img"
  onerror="this.src='/images/default-user.jpg'"
>
                  </div>

                  <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Full Name</div>
                    <div class="col-sm-8 fw-semibold">
                      <%= fullName %>
                    </div>
                  </div>
                  <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Email</div>
                    <div class="col-sm-8 fw-semibold">
                      <%= email %>
                    </div>
                  </div>
                  <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Phone Number</div>
                    <div class="col-sm-8 fw-semibold">
                      <%= phone %>
                    </div>
                  </div>
            </div>
          </div>
        </div>
      </main>

      <%- include("../partials/user/footer") %>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script>
          const successType = '<%= success || "" %>';
          if (successType === 'email-updated') {
            Swal.fire({
              icon: 'success',
              title: 'Success',
              text: 'Email updated successfully'
            });
          }
        </script>
</body>

</html>

</html>