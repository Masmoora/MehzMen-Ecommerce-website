<!DOCTYPE html>
<html lang="en">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">

   <title>My Addresses</title>

   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

   <link rel="stylesheet" href="/css/user/useradddress.css">
</head>

<body>

   <%- include("../partials/user/header") %>

      <main class="container py-4">
         <div class="row">

            <div class="col-lg-3">
               <%- include("../partials/user/profileSidebar",{ user, activeItem:"address"}) %>
            </div>

            <div class="col-lg-9">
               <div class="card card-soft p-4">
                  <div class="d-flex justify-content-between align-items-center mb-4">
                     <h4 class="mb-0">Your Addresses</h4>
                     <button class="btn btn-dark" id="addAddressBtn">+ Add Address</button>
                  </div>

                  <% if(addresses.length===0){ %>

                     <div class="empty-box">
                        <h5>No address added yet</h5>
                        <p class="text-muted">Add an address for faster checkout.</p>
                     </div>

                     <% } else { %>
                        <div class="row">

                           <% addresses.forEach((addr)=> { %>

                              <div class="col-md-6 mb-4">
                                 <div class="card p-3 shadow-sm">

                                    <h6>
                                       Address
                                       <% if (addr.isDefault) { %>
                                          <span class="badge bg-success py-1 px-2 small">Default Address</span>
                                          <% } %>
                                    </h6>

                                    <p><strong>Name:</strong>
                                       <%= addr.name %>
                                    </p>

                                    <p><strong>House No:</strong>
                                       <%= addr.houseNo %>
                                    </p>

                                    <p>
                                       <strong>City:</strong>
                                       <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %>
                                    </p>

                                    <p><strong>Country:</strong>
                                       <%= addr.country %>
                                    </p>

                                    <p><strong>Landmark:</strong>
                                       <%= addr.landMark %>
                                    </p>

                                    <p><strong>Phone:</strong>
                                       <%= addr.phone %>
                                    </p>

                                    <div class="d-flex gap-2">

                                       <button class="btn btn-sm btn-outline-primary editBtn" data-id="<%= addr._id %>"
                                          data-name="<%= addr.name %>" data-house="<%= addr.houseNo %>"
                                          data-city="<%= addr.city %>" data-state="<%= addr.state %>"
                                          data-landmark="<%= addr.landMark %>" data-pincode="<%= addr.pincode %>"
                                          data-country="<%= addr.country %>" data-phone="<%= addr.phone %>"
                                          data-default="<%= addr.isDefault %>">
                                          Edit
                                       </button>

                                       <button onclick="deleteAddress('<%= addr._id %>')"
                                          class="btn btn-sm btn-outline-danger">
                                          Delete
                                       </button>

                                    </div>

                                 </div>
                              </div>

                              <% }) %>

                        </div>
                        <% } %>

                           <% if(totalPages> 1){ %>
                              <nav class="mt-3">
                                 <ul class="pagination justify-content-center">
                                    <% for(let i=1;i<=totalPages;i++){ %>
                                       <li class="page-item <%= i === currentPage ? 'active':'' %>">
                                          <a class="page-link" href="/address?page=<%= i %>">
                                             <%= i %>
                                          </a>
                                       </li>
                                       <% } %>
                                 </ul>
                              </nav>
                              <% } %>

      </main>

      <!-- ADD ADDRESS MODAL -->

      <div class="modal fade" id="addressModal">
         <div class="modal-dialog modal-lg">
            <div class="modal-content">

               <div class="modal-header">
                  <h5>Add New Address</h5>
                  <button class="btn-close" data-bs-dismiss="modal"></button>
               </div>

               <form id="addressForm">
                  <div class="modal-body">

                     <div class="row g-3">

                        <div class="col-md-6">
                           <label>Full Name</label>
                           <input name="fullName" id="fullName" class="form-control">
                           <div class="text-danger small" id="fullNameError"></div>
                        </div>

                        <div class="col-md-6">
                           <label>Mobile</label>
                           <input name="mobile" id="mobile" class="form-control">
                           <div class="text-danger small" id="mobileError"></div>
                        </div>
                        <div class="col-md-6">
                           <label>House No</label>
                           <input name="houseNo" id="houseNo" class="form-control">
                        </div>
                        <div class="col-md-6">
                           <label>City</label>
                           <input name="city" id="city" class="form-control">
                           <div class="text-danger small" id="cityError"></div>
                        </div>

                        <div class="col-md-6">
                           <label>Landmark</label>
                           <input name="landmark" id="landmark" class="form-control">
                           <div class="text-danger small" id="landmarkError"></div>
                        </div>

                        <div class="col-md-6">
                           <label>State</label>
                           <input name="state" id="state" class="form-control">
                           <div class="text-danger small" id="stateError"></div>
                        </div>

                        <div class="col-md-6">
                           <label>Pincode</label>
                           <input name="pincode" id="pincode" class="form-control">
                           <div class="text-danger small" id="pincodeError"></div>
                        </div>

                        <div class="col-md-6">
                           <label>Country</label>
                           <input name="country" id="country" class="form-control" value="India">
                           <div class="text-danger small" id="countryError"></div>
                        </div>

                     </div>

                  </div>
                  <div class="col-md-6">
                     <label>
                        <input type="checkbox" name="isDefault" id="isDefault">Set as default Address
                     </label>
                  </div>

                  <div class="modal-footer">
                     <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                     <button type="submit" class="btn btn-dark">Save Address</button>
                  </div>

               </form>

            </div>
         </div>
      </div>

      <%- include("../partials/user/footer") %>

         <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
         <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

         <script>

            const addressForm = document.getElementById('addressForm');
            const addressModalEl = document.getElementById('addressModal');
            const modal = new bootstrap.Modal(addressModalEl);
            const addBtn = document.getElementById('addAddressBtn');

            // ✅ OPEN ADD MODAL
            if (addBtn) {
               addBtn.addEventListener('click', () => {

                  addressForm.reset();

                  // remove edit mode
                  delete addressForm.dataset.editId;

                  modal.show();
               });
            }


            // ✅ OPEN EDIT MODAL
            document.querySelectorAll('.editBtn').forEach(btn => {

               btn.addEventListener('click', () => {

                  // set edit mode id
                  addressForm.dataset.editId = btn.dataset.id;

                  // fill existing data
                  document.getElementById('fullName').value = btn.dataset.name;
                  document.getElementById('mobile').value = btn.dataset.phone;
                  document.getElementById('houseNo').value = btn.dataset.house;
                  document.getElementById('city').value = btn.dataset.city;
                  document.getElementById('state').value = btn.dataset.state;
                  document.getElementById('landmark').value = btn.dataset.landmark;
                  document.getElementById('pincode').value = btn.dataset.pincode;
                  document.getElementById('country').value = btn.dataset.country;
                  document.getElementById('isDefault').checked =
                     btn.dataset.default === "true";

                  modal.show();

               });

            });


            addressModalEl.addEventListener('hidden.bs.modal', function () {
               addressForm.reset();
               document.querySelectorAll('.text-danger')
                  .forEach(e => e.textContent = "");
            });


            // ✅ FORM SUBMIT (ADD + EDIT BOTH)
            addressForm.addEventListener('submit', async (e) => {

               e.preventDefault();

               const fullName = document.getElementById('fullName').value.trim();
               const mobile = document.getElementById('mobile').value.trim();
               const city = document.getElementById('city').value.trim();
               const landmark = document.getElementById('landmark').value.trim();
               const state = document.getElementById('state').value.trim();
               const pincode = document.getElementById('pincode').value.trim();
               const country = document.getElementById('country').value.trim();

               document.querySelectorAll('.text-danger')
                  .forEach(e => e.textContent = "");

               let isValid = true;

               if (!fullName) {
                  document.getElementById('fullNameError').textContent = "Full name required";
                  isValid = false;
               }

               if (!mobile || mobile.length !== 10) {
                  document.getElementById('mobileError').textContent = "Valid 10 digit mobile required";
                  isValid = false;
               }

               if (!city) {
                  document.getElementById('cityError').textContent = "City required";
                  isValid = false;
               }

               if (!landmark) {
                  document.getElementById('landmarkError').textContent = "Landmark required";
                  isValid = false;
               }

               if (!state) {
                  document.getElementById('stateError').textContent = "State required";
                  isValid = false;
               }

               if (!pincode || pincode.length !== 6) {
                  document.getElementById('pincodeError').textContent = "Valid pincode required";
                  isValid = false;
               }

               if (!country) {
                  document.getElementById('countryError').textContent = "Country required";
                  isValid = false;
               }

               if (!isValid) return;


               const formData = new FormData(addressForm);
               const data = Object.fromEntries(formData.entries());

               // 🔥 detect add or edit automatically
               const editId = addressForm.dataset.editId;
               const url = editId ? `/edit-address/${editId}` : '/add-address';


               try {

                  const response = await fetch(url, {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json' },
                     body: JSON.stringify(data)
                  });

                  const result = await response.json();

                  if (response.ok && result.success) {

                     Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: editId ? 'Address updated successfully' : 'Address added successfully',
                        timer: 1200,
                        showConfirmButton: false
                     })
                        .then(() => {

                           modal.hide();
                           location.reload(); // simple refresh version

                        });

                  } else {

                     Swal.fire('Error', result.message || 'Failed', 'error');

                  }

               } catch (err) {

                  console.log(err);

                  Swal.fire('Error', 'Something went wrong', 'error');

               }

            });
            async function deleteAddress(id) {

               const confirm = await Swal.fire({
                  title: 'Delete Address?',
                  text: 'This cannot be undone',
                  icon: 'warning',
                  showCancelButton: true,
                  confirmButtonText: 'Yes Delete'
               });

               if (!confirm.isConfirmed) return;

               try {

                  const res = await fetch(`/delete-address/${id}`, {
                     method: 'POST'
                  });

                  const result = await res.json();

                  if (result.success) {

                     Swal.fire({
                        icon: 'success',
                        title: 'Deleted',
                        timer: 1200,
                        showConfirmButton: false
                     }).then(() => {
                        location.reload();
                     });

                  } else {
                     Swal.fire('Error', result.message, 'error');
                  }

               } catch (err) {

                  Swal.fire('Error', 'Something went wrong', 'error');

               }

            }

         </script>

</body>

</html>