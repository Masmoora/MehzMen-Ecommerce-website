<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - MehzMen</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/user/login.css">

</head>

<body>

    <div class="login-card">

        <!-- LEFT SECTION -->
        <div class="left-section">

            <div class="brand-title">MehzMen</div>
            <a href="/auth/google" class="google-btn text-decoration-none">
                <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google" width="20">
                Login with Google
            </a>

            <div class="divider">— or —</div>

            <form action="/login" method="POST">
                <input type="email" name="email" class="form-control" placeholder="Email" required>
                <input type="password" name="password" class="form-control" placeholder="Password" required>
                <!-- Error Message -->
                <% if(locals.message && message.length> 0){ %>
                    <div class="alert alert-danger text-center mt-2">
                        <%= message %>
                    </div>
                    <% } %>

                        <div class="text-end">
                            <a href="/forgot-password" class="text-decoration-none small">Forgot password?</a>
                        </div>

                        <button class="login-btn">Login</button>
            </form>

            <div class="bottom-text">
                New User? <a href="/signup" class="fw-bold text-decoration-none">Sign up now..!</a>
            </div>

        </div>

        <!-- RIGHT SECTION -->
        <div class="right-section">
            <img src="/images/login.webp" alt="Fashion Image">
        </div>

    </div>

</body>

</html>