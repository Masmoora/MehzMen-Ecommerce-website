<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Products</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/user/allProducts.css">
</head>

<body>

<%- include("../partials/user/header") %>

<%
  function buildQuery(newParams) {
    const current = { page, search, category: selectedCategory, brand: selectedBrand, color: selectedColor, minPrice, maxPrice, sort };
    const merged = { ...current, ...newParams };

    return Object.entries(merged)
      .filter(([_, v]) => v !== null && v !== undefined && v !== '')
      .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
      .join('&');
  }
%>

<main class="container pt-2 pb-4">
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
    <h2 class="mb-2 mb-md-0">All Products</h2>
    <form class="d-flex gap-2" method="GET" action="/allProducts">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
      <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
      <input type="hidden" name="color" value="<%= selectedColor || '' %>">
      <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
      <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
      <input type="hidden" name="sort" value="<%= sort || '' %>">
      <input class="form-control" type="text" name="search" placeholder="Search products" value="<%= search || '' %>">
      <button class="btn btn-dark" type="submit"><i class="bi bi-search"></i></button>
      <a href="/allProducts" class="btn btn-outline-secondary">Clear</a>
    </form>
  </div>

  <div class="row g-4">
    <!-- Sidebar -->
    <div class="col-12 col-lg-3">
      <div class="sidebar-box">
        <h6 class="mb-2">Category</h6>
        <form method="GET" action="/allProducts">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
          <input type="hidden" name="color" value="<%= selectedColor || '' %>">
          <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
          <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">
          <select class="form-select" name="category" onchange="this.form.submit()">
            <option value="" <%= !selectedCategory ? 'selected' : '' %>>All</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>" <%= selectedCategory === cat._id.toString() ? 'selected' : '' %>>
                <%= cat.name %>
              </option>
            <% }) %>
          </select>
        </form>
      </div>

      <div class="sidebar-box">
        <h6 class="mb-2">Brand</h6>
        <form method="GET" action="/allProducts">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
          <input type="hidden" name="color" value="<%= selectedColor || '' %>">
          <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
          <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">
          <select class="form-select" name="brand" onchange="this.form.submit()">
            <option value="" <%= !selectedBrand ? 'selected' : '' %>>All</option>
            <% brands.forEach(br => { %>
              <option value="<%= br._id %>" <%= selectedBrand === br._id.toString() ? 'selected' : '' %>>
                <%= br.name %>
              </option>
            <% }) %>
          </select>
        </form>
      </div>

      <div class="sidebar-box">
        <h6 class="mb-2">Color</h6>
        <form method="GET" action="/allProducts">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
          <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
          <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
          <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">
          <select class="form-select" name="color" onchange="this.form.submit()">
            <option value="" <%= !selectedColor ? 'selected' : '' %>>All</option>
            <% colors.forEach(color => { %>
              <option value="<%= color %>" <%= selectedColor && selectedColor.toLowerCase() === color.toLowerCase() ? 'selected' : '' %>>
                <%= color %>
              </option>
            <% }) %>
          </select>
        </form>
      </div>

      <div class="sidebar-box">
        <h6 class="mb-2">Price Range</h6>
        <form method="GET" action="/allProducts">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
          <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
          <input type="hidden" name="color" value="<%= selectedColor || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">
          <div class="d-flex gap-2">
            <input class="form-control" type="number" name="minPrice" placeholder="Min" value="<%= minPrice || '' %>">
            <input class="form-control" type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice || '' %>">
          </div>
          <button class="btn btn-dark w-100 mt-2">Apply</button>
        </form>
      </div>
    </div>

    <!-- Products -->
    <div class="col-12 col-lg-9">
      <form method="GET" class="mb-3">
        <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
        <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
        <input type="hidden" name="color" value="<%= selectedColor || '' %>">
        <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
        <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
        <input type="hidden" name="search" value="<%= search || '' %>">
        <select class="form-select w-auto" name="sort" onchange="this.form.submit()">
          <option value="">Sort By</option>
          <option value="lowToHigh" <%= sort === 'lowToHigh' ? 'selected' : '' %>>Low to High</option>
          <option value="highToLow" <%= sort === 'highToLow' ? 'selected' : '' %>>High to Low</option>
          <option value="aToZ" <%= sort === 'aToZ' ? 'selected' : '' %>>A–Z</option>
          <option value="zToA" <%= sort === 'zToA' ? 'selected' : '' %>>Z–A</option>
        </select>
      </form>

      <div class="row g-4">
        <% if (products && products.length > 0) { %>
          <% for (let i = 0; i < products.length; i++) { %>
            <% const isWishlisted = wishlistProductIds && wishlistProductIds.includes(products[i]._id.toString()); %>
            <div class="col-12 col-md-6 col-lg-4">
              <div class="product-card">
<button
  type="button"
  class="wishlist-btn <%= isWishlisted ? 'active' : '' %>"
  data-product-id="<%= products[i]._id %>"
  aria-label="Add to wishlist"
  title="Add to wishlist"
>
  <i class="bi <%= isWishlisted ? 'bi-heart-fill text-danger' : 'bi-heart' %>"></i>
</button>
                <a href="/productDetails/<%= products[i]._id %>?variant=<%= products[i].variantId %>" class="text-decoration-none text-dark">
                  <img src="<%= products[i].image %>" alt="<%= products[i].name %>">
                  <h6 class="product-title mt-2 mb-1"><%= products[i].name %></h6>
                  <p class="mb-0">Brand: <%= products[i].brandName %></p>
                  <p class="mb-0">
                    <% if (products[i].discountAmount && products[i].discountAmount > 0) { %>
                      <span class="text-muted text-decoration-line-through me-1">
                        ₹<%= products[i].originalPrice %>
                      </span>
                      <span class="price-text text-danger">
                        ₹<%= products[i].price %>
                      </span>
                      <span class="badge bg-success ms-1">
                        -<%= products[i].discountPercent %>%
                      </span>
                    <% } else { %>
                      <span class="price-text">Starting from ₹<%= products[i].price %></span>
                    <% } %>
                  </p>
                </a>
              </div>
            </div>
          <% } %>
        <% } else { %>
          <p>No products found.</p>
        <% } %>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination justify-content-center mt-4">
          <% if (page > 1) { %>
            <a class="btn" href="/allProducts?<%= buildQuery({ page: page - 1 }) %>">Prev</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a class="btn <%= page === i ? 'active' : '' %>" href="/allProducts?<%= buildQuery({ page: i }) %>"><%= i %></a>
          <% } %>
          <% if (page < totalPages) { %>
            <a class="btn" href="/allProducts?<%= buildQuery({ page: page + 1 }) %>">Next</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  (function () {
    const wishlistButtons = document.querySelectorAll('.wishlist-btn[data-product-id]');

    wishlistButtons.forEach((btn) => {
      btn.addEventListener('click', async (event) => {
        event.preventDefault();
        event.stopPropagation();

        const productId = btn.getAttribute('data-product-id');
        if (!productId) return;

        try {
          const res = await fetch('/wishlist/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId })
          });

          const data = await res.json();

          if (res.status === 401) {
            await Swal.fire('Login required', 'Please login to use wishlist', 'info');
            window.location.href = '/login';
            return;
          }

          if (!res.ok || !data.success) {
            Swal.fire('Error', data.message || 'Failed to add wishlist', 'error');
            return;
          }

          btn.classList.add('active');
          btn.innerHTML = '<i class="bi bi-heart-fill"></i>';
          Swal.fire('Success', data.message || 'Added to wishlist', 'success');
        } catch (error) {
          Swal.fire('Error', 'Something went wrong while adding to wishlist', 'error');
        }
      });
    });
  })();
</script>

</body>
</html>