<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Products</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

  <style>
    body { background: #f6f7fb; padding-top: 60px; }
    .sidebar-box {
      background: #fff;
      padding: 18px;
      border-radius: 10px;
      margin-bottom: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }
    .product-card {
      background: #fff;
      border: 1px solid #eee;
      border-radius: 12px;
      padding: 14px;
      transition: all 0.2s ease;
      position: relative;
    }
    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    }
    .product-card img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      border-radius: 8px;
    }
    .product-title {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.2px;
    }
    .price-text {
      font-weight: 700;
      color: #111;
    }
    .wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
      color: #111;
      text-decoration: none;
    }
    .wishlist-btn i {
      font-size: 0.95rem;
    }
    .filter-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .filter-list li {
      margin-bottom: 8px;
    }
    .filter-link {
      display: block;
      background: #f1f1f1;
      color: #333;
      padding: 10px 14px;
      border-radius: 8px;
      text-align: center;
      text-decoration: none;
      transition: all 0.2s ease;
      font-weight: 500;
    }
    .filter-link:hover {
      background: #222;
      color: #fff;
    }
    .filter-link.active {
      background: #222;
      color: #fff;
    }
  </style>
</head>
<body>

<%- include("../partials/user/header") %>

<%
  function buildQuery(newParams) {
    const current = { page, search, category: selectedCategory, brand: selectedBrand, minPrice, maxPrice, sort };
    const merged = { ...current, ...newParams };

    return Object.entries(merged)
      .filter(([_, v]) => v !== null && v !== undefined && v !== '')
      .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
      .join('&');
  }
%>

<main class="container pt-2 pb-4">
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
    <h2 class="mb-2 mb-md-0">All Products</h2>
    <form class="d-flex gap-2" method="GET" action="/allProducts">
      <input type="hidden" name="page" value="1">
      <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
      <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
      <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
      <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
      <input type="hidden" name="sort" value="<%= sort || '' %>">
      <input class="form-control" type="text" name="search" placeholder="Search products" value="<%= search || '' %>">
      <button class="btn btn-dark" type="submit"><i class="bi bi-search"></i></button>
      <a href="/allProducts" class="btn btn-outline-secondary">Clear</a>
    </form>
  </div>

  <div class="row g-4">
    <!-- Sidebar -->
    <div class="col-12 col-lg-3">
      <div class="sidebar-box">
        <h6 class="mb-2">Browse Categories</h6>
        <ul class="filter-list">
          <li>
            <a
              href="/allProducts?<%= buildQuery({ category: '', page: 1 }) %>"
              class="filter-link <%= !selectedCategory ? 'active' : '' %>"
            >
              All
            </a>
          </li>
          <% categories.forEach(cat => { %>
            <li>
              <a
                href="/allProducts?<%= buildQuery({ category: cat._id, page: 1 }) %>"
                class="filter-link <%= selectedCategory === cat._id.toString() ? 'active' : '' %>"
              >
                <%= cat.name %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="sidebar-box">
        <h6 class="mb-2">Browse Brands</h6>
        <ul class="filter-list">
          <li>
            <a
              href="/allProducts?<%= buildQuery({ brand: '', page: 1 }) %>"
              class="filter-link <%= !selectedBrand ? 'active' : '' %>"
            >
              All
            </a>
          </li>
          <% brands.forEach(br => { %>
            <li>
              <a
                href="/allProducts?<%= buildQuery({ brand: br._id, page: 1 }) %>"
                class="filter-link <%= selectedBrand === br._id.toString() ? 'active' : '' %>"
              >
                <%= br.name %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="sidebar-box">
        <h6 class="mb-2">Price Range</h6>
        <form method="GET" action="/allProducts">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="search" value="<%= search || '' %>">
          <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
          <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
          <input type="hidden" name="sort" value="<%= sort || '' %>">
          <div class="d-flex gap-2">
            <input class="form-control" type="number" name="minPrice" placeholder="Min" value="<%= minPrice || '' %>">
            <input class="form-control" type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice || '' %>">
          </div>
          <button class="btn btn-dark w-100 mt-2">Apply</button>
        </form>
      </div>
    </div>

    <!-- Products -->
    <div class="col-12 col-lg-9">
      <form method="GET" class="mb-3">
        <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
        <input type="hidden" name="brand" value="<%= selectedBrand || '' %>">
        <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
        <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">
        <input type="hidden" name="search" value="<%= search || '' %>">
        <select class="form-select w-auto" name="sort" onchange="this.form.submit()">
          <option value="">Sort By</option>
          <option value="lowToHigh" <%= sort === 'lowToHigh' ? 'selected' : '' %>>Low to High</option>
          <option value="highToLow" <%= sort === 'highToLow' ? 'selected' : '' %>>High to Low</option>
          <option value="aToZ" <%= sort === 'aToZ' ? 'selected' : '' %>>A–Z</option>
          <option value="zToA" <%= sort === 'zToA' ? 'selected' : '' %>>Z–A</option>
        </select>
      </form>

      <div class="row g-4">
        <% if (products && products.length > 0) { %>
          <% for (let i = 0; i < products.length; i++) { %>
            <div class="col-12 col-md-6 col-lg-4">
              <a href="/productDetails/<%= products[i]._id %>" class="text-decoration-none text-dark">
                <div class="product-card">
                  <span class="wishlist-btn">
                    <i class="bi bi-heart"></i>
                  </span>
                  <img src="<%= products[i].image %>" alt="<%= products[i].name %>">
                  <h6 class="product-title mt-2 mb-1"><%= products[i].name %></h6>
                  <p class="mb-0">Brand: <%= products[i].brandName %></p>
                  <p class="mb-0 price-text">Starting from ₹<%= products[i].price %></p>
                </div>
              </a>
            </div>
          <% } %>
        <% } else { %>
          <p>No products found.</p>
        <% } %>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination justify-content-center mt-4">
          <% if (page > 1) { %>
            <a class="btn" href="/allProducts?<%= buildQuery({ page: page - 1 }) %>">Prev</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a class="btn <%= page === i ? 'active' : '' %>" href="/allProducts?<%= buildQuery({ page: i }) %>"><%= i %></a>
          <% } %>
          <% if (page < totalPages) { %>
            <a class="btn" href="/allProducts?<%= buildQuery({ page: page + 1 }) %>">Next</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include("../partials/user/footer") %>

</body>
</html>



