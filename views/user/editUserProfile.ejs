<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/user/editUserProfile.css">

</head>

<body>
  <%- include("../partials/user/header") %>

    <% const profileImage=(user && (user.profileImage || user.avatar)) || 'https://via.placeholder.com/140' ; const
      name=(user && user.name) ? user.name : '' ; const email=(user && user.email) ? user.email : '' ; const phone=(user
      && user.phone) ? user.phone : '' ; const successMessage=success==='password-updated'
      ? 'Password updated successfully' : '' ; %>

      <main class="container py-4">
        <div class="row g-4">
          <div class="col-12 col-lg-3">
            <%- include("../partials/user/profileSidebar", { user, activeItem: "account" }) %>
          </div>
          <div class="col-12 col-lg-9">
            <div class="card card-soft p-4 mb-4">
              <% if (successMessage) { %>
                <div class="alert alert-success" role="alert">
                  <%= successMessage %>
                </div>
                <% } %>
                  <h4 class="mb-3">Edit Profile</h4>

                  <form action="/edit-userProfile" method="POST" enctype="multipart/form-data" onsubmit="return validateProfileForm()">
                    <div class="d-flex align-items-center gap-3 mb-4">
                      <img name="profileImage" id="profilePreview" src="<%= profileImage %>" alt="Profile"
                        class="rounded-circle profile-img">
                      <div>
                        <button type="button" class="btn btn-outline-dark" id="changePhotoBtn">
                          <i class="bi bi-camera me-1"></i>Change Profile Picture
                        </button>
                        <input type="file" id="profileImageInput" name="profileImage" class="d-none" accept="image/*">
                      </div>
                    </div>

                    <div class="row g-3">
                      <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control" name="name" value="<%= name %>">
                        <small class="text-danger profile-error"></small>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <div class="input-group">
                          <input type="email" class="form-control" value="<%= email %>" readonly>
                          <a href="/change-email" class="btn btn-sm btn-link">Change Email</a>
                        </div>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input type="text" class="form-control" name="phone" value="<%= phone %>">
                        <small class="text-danger profile-error"></small>
                      </div>

                    </div>

                    <div class="d-flex gap-2 mt-4">
                      <button type="submit" class="btn btn-dark">Save Changes</button>
                      <a href="/profile" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                  </form>
            </div>

            <div class="card card-soft p-4">
              <h5 class="mb-3">Change Password</h5>
              <form id="changePasswordForm">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Current Password</label>
                    <input type="password" class="form-control" id="currentPassword" name="currentPassword">
                    <small class="text-danger error-msg" id="currentPasswordError"></small>
                    <!-- ✅ Forgot password link -->
                    <div class="mt-1">
                      <a href="/forgot-password" class="small text-decoration-none">
                        Forgot Password?
                      </a>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">New Password</label>
                    <input type="password" class="form-control" id="newPassword" name="newPassword">
                    <small class="text-danger error-msg" id="newPasswordError"></small>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Confirm New Password</label>
                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword">
                    <small class="text-danger error-msg" id="confirmPasswordError"></small>
                  </div>
                </div>
                <div class="mt-3">
                  <button type="submit" class="btn btn-dark">Update Password</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </main>

      <%- include("../partials/user/footer") %>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


        <script>
          const changePhotoBtn = document.getElementById('changePhotoBtn');
          const profileInput = document.getElementById('profileImageInput');
          const profilePreview = document.getElementById('profilePreview');

          if (changePhotoBtn && profileInput) {
            changePhotoBtn.addEventListener('click', () => profileInput.click());
          }

          if (profileInput && profilePreview) {
            profileInput.addEventListener('change', (event) => {
              const file = event.target.files && event.target.files[0];
              if (file) {
                profilePreview.src = URL.createObjectURL(file);
              }
            });
          }


          $(document).ready(function () {

            $('#changePasswordForm').on('submit', function (e) {

              e.preventDefault();

              // clear previous errors
              $('.error-msg').text('');

              const currentPassword = $('#currentPassword').val().trim();
              const newPassword = $('#newPassword').val().trim();
              const confirmPassword = $('#confirmPassword').val().trim();

              let isValid = true;

              // VALIDATION

              if (!currentPassword) {
                $('#currentPasswordError').text('Current password required');
                isValid = false;
              }

              if (!newPassword) {
                $('#newPasswordError').text('New password required');
                isValid = false;
              } else if (newPassword.length < 6) {
                $('#newPasswordError').text('Minimum 6 characters required');
                isValid = false;
              }

              if (!confirmPassword) {
                $('#confirmPasswordError').text('Confirm your password');
                isValid = false;
              } else if (newPassword !== confirmPassword) {
                $('#confirmPasswordError').text('Passwords do not match');
                isValid = false;
              }

              if (!isValid) return;

              // AJAX

              $.ajax({
                type: 'POST',
                url: '/change-password',
                data: {
                  currentPassword,
                  newPassword,
                  confirmPassword
                },
                success: function (res) {

                  if (res.success) {
                    Swal.fire('Success', 'Password changed', 'success');
                    $('#changePasswordForm')[0].reset();
                  } else {
                    Swal.fire('Error', res.message, 'error');
                  }
                },
                error: function () {
                  Swal.fire('Error', 'Server error', 'error');
                }
              });

            });

          });



function validateProfileForm() {

  const name = document.querySelector('input[name="name"]').value.trim();
  const phone = document.querySelector('input[name="phone"]').value.trim();

  let isValid = true;

  // clear previous errors (optional)
  document.querySelectorAll('.profile-error').forEach(el => el.textContent = '');

  // ✅ NAME VALIDATION
  const nameRegex = /^[^_.][A-Za-z\s]*$/;

  if (!name) {
    showError('name', 'Name is required');
    isValid = false;
  } else if (!nameRegex.test(name)) {
    showError('name', "Name should not start with '_' or '.' and only letters allowed");
    isValid = false;
  }

  // ✅ PHONE VALIDATION (optional but recommended)
  const phoneRegex = /^[6-9]\d{9}$/;

  if (phone && !phoneRegex.test(phone)) {
    showError('phone', 'Enter valid 10-digit phone number');
    isValid = false;
  }

  return isValid;
}

// helper function
function showError(fieldName, message) {
  let input = document.querySelector(`[name="${fieldName}"]`);
  
  let error = input.nextElementSibling;
  
  if (!error || !error.classList.contains('profile-error')) {
    error = document.createElement('small');
    error.className = 'text-danger profile-error';
    input.parentNode.appendChild(error);
  }

  error.textContent = message;
}


        </script>
        
</body>

</html>