<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - Details</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    body { background: #f6f7fb; padding-top: 60px; }
    .zoom-container {
      position: relative;
    }
    .gallery-main {
      width: 100%;
      height: 420px;
      object-fit: cover;
      border-radius: 12px;
      transition: transform 0.3s ease;
      cursor: zoom-in;
    }
    .gallery-main:hover {
      transform: scale(1.03);
    }
    .zoom-lens {
      position: absolute;
      border: 2px solid #111;
      width: 120px;
      height: 120px;
      background: rgba(255, 255, 255, 0.3);
      display: none;
      cursor: crosshair;
    }
    .zoom-result {
      width: 100%;
      height: 420px;
      border-radius: 12px;
      border: 1px solid #eee;
      background-repeat: no-repeat;
      background-size: 200% 200%;
      display: none;
      transition: opacity 0.2s ease;
      opacity: 0;
    }
    .zoom-result.active {
      display: block;
      opacity: 1;
    }
    .zoom-icon {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
      cursor: zoom-in;
    }
    .thumb {
      width: 70px;
      height: 70px;
      object-fit: cover;
      border-radius: 8px;
      border: 2px solid transparent;
      cursor: pointer;
    }
    .thumb.active {
      border-color: #111;
    }
    .variant-btn {
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px 12px;
      background: #fff;
      cursor: pointer;
    }
    .variant-btn.active {
      background: #111;
      color: #fff;
      border-color: #111;
    }
    .price-text {
      font-size: 1.5rem;
      font-weight: 700;
    }
    .badge-availability {
      font-size: 0.9rem;
    }
  </style>
</head>
<body>

<%- include("../partials/user/header") %>

<main class="container py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item">
        <a href="/allProducts?category=<%= product.category?._id || '' %>">
          <%= product.category?.name || 'Category' %>
        </a>
      </li>
      <li class="breadcrumb-item active" aria-current="page"><%= product.name %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Image Gallery -->
    <div class="col-12 col-lg-6">
      <div class="zoom-container">
        <img id="mainImage" class="gallery-main" src="" alt="<%= product.name %>">
        <div id="zoomLens" class="zoom-lens"></div>
        <div id="zoomIcon" class="zoom-icon">
          <i class="fa-solid fa-magnifying-glass-plus"></i>
        </div>
      </div>
      <div id="zoomResult" class="zoom-result mt-3"></div>
      <div id="thumbContainer" class="d-flex gap-2 mt-3 flex-wrap"></div>
    </div>

    <!-- Product Info -->
    <div class="col-12 col-lg-6">
      <h2><%= product.name %></h2>
      <p class="text-muted">Brand: <%= product.brand?.name || 'N/A' %></p>
      <p class="text-muted">Category: <%= product.category?.name || 'N/A' %></p>
      <p><%= product.description %></p>

      <div class="mb-3">
        <span class="price-text">₹<span id="priceText"></span></span>
      </div>

      <div class="mb-3">
        <span id="stockBadge" class="badge badge-availability"></span>
      </div>

      <div class="mb-3">
        <h6>Size</h6>
        <div id="sizeOptions" class="d-flex gap-2 flex-wrap"></div>
      </div>

      <div class="mb-3">
        <h6>Color</h6>
        <div id="colorOptions" class="d-flex gap-2 flex-wrap"></div>
      </div>

      <div class="mb-3">
        <button id="addToCartBtn" class="btn btn-dark">Add to Cart</button>
        <button id="addToWishlistBtn" class="btn btn-dark">Add to Wishlist</button>
        <p id="unavailableMsg" class="text-danger mt-2 d-none">This product is currently unavailable.</p>
      </div>

      <div class="mt-4">
        <h6>Highlights</h6>
        <ul>
          <li>Premium fabric</li>
          <li>Comfort fit</li>
          <li>Easy to maintain</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Ratings & Reviews (Placeholder) -->
  <div class="mt-5">
    <h5>Ratings & Reviews</h5>
    <div class="mb-2 text-warning">
      <i class="bi bi-star-fill"></i>
      <i class="bi bi-star-fill"></i>
      <i class="bi bi-star-fill"></i>
      <i class="bi bi-star-fill"></i>
      <i class="bi bi-star"></i>
    </div>
    <p class="text-muted">No reviews yet. Be the first to review this product.</p>
  </div>

  <!-- Related Products -->
  <div class="mt-5">
    <h5>Related Products</h5>
    <div class="row g-4 mt-1">
      <% if (relatedProducts && relatedProducts.length) { %>
        <% relatedProducts.forEach(item => { %>
          <div class="col-12 col-md-6 col-lg-3">
            <a href="/productDetails/<%= item._id %>" class="text-decoration-none text-dark">
                            <div class="card h-100">
                <img src="<%= item.image %>" class="card-img-top" alt="<%= item.name %>">
                <div class="card-body">
                  <h6 class="card-title mb-1"><%= item.name %></h6>
                  <small class="text-muted">Brand: <%= item.brandName %></small>
                  <div class="mt-2 fw-bold">₹<%= item.price %></div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No related products found.</p>
      <% } %>
    </div>
  </div>
</main>

<%- include("../partials/user/footer") %>

<script type="application/json" id="variantData">
  <%- JSON.stringify(variants) %>
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const variants = JSON.parse(document.getElementById('variantData').textContent);
  const params = new URLSearchParams(window.location.search);
  const initialVariantId = params.get('variant');

  const initialVariant =
    variants.find(v => v._id === initialVariantId) || variants[0];

  let selectedVariant = initialVariant;
  let selectedColor = selectedVariant ? selectedVariant.color : null;
  let selectedSize = selectedVariant ? selectedVariant.size : null;

  const mainImage = document.getElementById('mainImage');
  const zoomLens = document.getElementById('zoomLens');
  const zoomResult = document.getElementById('zoomResult');
  const zoomIcon = document.getElementById('zoomIcon');
  const thumbContainer = document.getElementById('thumbContainer');
  const sizeOptions = document.getElementById('sizeOptions');
  const colorOptions = document.getElementById('colorOptions');
  const priceText = document.getElementById('priceText');
  const stockBadge = document.getElementById('stockBadge');
  const addToCartBtn = document.getElementById('addToCartBtn');
  const addToWishlistBtn = document.getElementById('addToWishlistBtn');
  const unavailableMsg = document.getElementById('unavailableMsg');
  let zoomLocked = false;

  function renderImages(images) {
    thumbContainer.innerHTML = '';
    mainImage.src = images[0] || '';
    zoomResult.style.backgroundImage = mainImage.src ? `url('${mainImage.src}')` : '';
    zoomIcon.style.display = mainImage.src ? 'flex' : 'none';

    images.forEach((img, index) => {
      const thumb = document.createElement('img');
      thumb.src = img;
      thumb.className = 'thumb' + (index === 0 ? ' active' : '');
      thumb.addEventListener('click', () => {
        document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
        mainImage.src = img;
        zoomResult.style.backgroundImage = `url('${img}')`;
      });
      thumbContainer.appendChild(thumb);
    });
  }

  function renderOptions() {
    const colors = [...new Set(variants.map(v => v.color))];
    const sizesForColor = variants
      .filter(v => v.color === selectedColor)
      .map(v => v.size);
    const sizes = [...new Set(sizesForColor)];

    colorOptions.innerHTML = '';
    colors.forEach(color => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'variant-btn' + (color === selectedColor ? ' active' : '');
      btn.textContent = color;
      btn.addEventListener('click', () => updateVariant({ color }));
      colorOptions.appendChild(btn);
    });

    sizeOptions.innerHTML = '';
    sizes.forEach(size => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'variant-btn' + (size === selectedSize ? ' active' : '');
      btn.textContent = size;
      btn.addEventListener('click', () => updateVariant({ size }));
      sizeOptions.appendChild(btn);
    });
  }

  function updateVariant(change) {
    if (change.color) {
      selectedColor = change.color;
      // reset size to the first available size for this color
      const firstSize = variants.find(v => v.color === selectedColor)?.size;
      selectedSize = firstSize || selectedSize;
    }

    if (change.size) {
      selectedSize = change.size;
    }

    const next = variants.find(v => v.color === selectedColor && v.size === selectedSize);
    if (!next) return;

    selectedVariant = next;
    applyVariant();
  }

  function applyVariant() {
    priceText.textContent = selectedVariant.price;
    renderImages(selectedVariant.images || []);
    renderOptions();

    if (!selectedVariant.isActive) {
      stockBadge.className = 'badge bg-secondary badge-availability';
      stockBadge.textContent = 'Unavailable';
      addToCartBtn.disabled = true;
      unavailableMsg.classList.remove('d-none');
      return;
    }

    if (selectedVariant.stock > 0) {
      stockBadge.className = 'badge bg-success badge-availability';
      stockBadge.textContent = 'In Stock';
      addToCartBtn.disabled = false;
      unavailableMsg.classList.add('d-none');
    } else {
      stockBadge.className = 'badge bg-danger badge-availability';
      stockBadge.textContent = 'Out of Stock';
      addToCartBtn.disabled = true;
      unavailableMsg.classList.remove('d-none');
    }
  }

  function moveLens(e) {
    const rect = mainImage.getBoundingClientRect();
    let x = e.clientX - rect.left - zoomLens.offsetWidth / 2;
    let y = e.clientY - rect.top - zoomLens.offsetHeight / 2;

    if (x < 0) x = 0;
    if (y < 0) y = 0;
    if (x > rect.width - zoomLens.offsetWidth) x = rect.width - zoomLens.offsetWidth;
    if (y > rect.height - zoomLens.offsetHeight) y = rect.height - zoomLens.offsetHeight;

    zoomLens.style.left = x + 'px';
    zoomLens.style.top = y + 'px';

    const xPercent = (x / rect.width) * 100;
    const yPercent = (y / rect.height) * 100;
    zoomResult.style.backgroundPosition = `${xPercent}% ${yPercent}%`;
  }

  function enableZoom() {
    if (!mainImage.src) return;
    zoomResult.style.backgroundImage = `url('${mainImage.src}')`;
    zoomLens.style.display = 'block';
    zoomResult.classList.add('active');
  }

  function disableZoom() {
    zoomLens.style.display = 'none';
    zoomResult.classList.remove('active');
  }

  mainImage.addEventListener('mousemove', moveLens);
  zoomLens.addEventListener('mousemove', moveLens);

  mainImage.addEventListener('mouseenter', () => {
    if (!zoomLocked) enableZoom();
  });
  mainImage.addEventListener('mouseleave', () => {
    if (!zoomLocked) disableZoom();
  });

  zoomIcon.addEventListener('click', () => {
    zoomLocked = !zoomLocked;
    if (zoomLocked) {
      enableZoom();
    } else {
      disableZoom();
    }
  });

  mainImage.addEventListener('error', () => {
    zoomIcon.style.display = 'none';
    disableZoom();
  });

  mainImage.addEventListener('load', () => {
    zoomIcon.style.display = 'flex';
  });
   // Add to cart with selected variant
  addToCartBtn.addEventListener('click', async () => {
    if (!selectedVariant) return;

    const res = await fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        productId: '<%= product._id %>',
        variantId: selectedVariant._id,
        quantity: 1
      })
    });

    const data = await res.json();
    if (data.success) {
      await Swal.fire('Success', 'Added to cart', 'success');
      window.location.href = '/cart';
    } else {
      Swal.fire('Error', data.message || 'Failed to add cart', 'error');
    }
  });
    // Add product to wishlist
  addToWishlistBtn.addEventListener('click', async () => {
    const res = await fetch('/wishlist/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId: '<%= product._id %>' })
    });

    const data = await res.json();
    if (data.success) {
      Swal.fire('Success', data.message || 'Added to wishlist', 'success');
    } else {
      Swal.fire('Error', data.message || 'Failed to add wishlist', 'error');
    }
  });

  applyVariant();
</script>

</body>
</html>



