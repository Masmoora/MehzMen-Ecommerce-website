<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Invoice <%= order.orderId %></title>
  <style>
    body { font-family: Arial, sans-serif; color: #222; font-size: 12px; }
    h1, h2, h3 { margin: 0; }
    .mb-10 { margin-bottom: 10px; }
    .mb-20 { margin-bottom: 20px; }
    .row { display: flex; justify-content: space-between; }
    table { width: 100%; border-collapse: collapse; margin-top: 12px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background: #f5f5f5; }
    .text-right { text-align: right; }
  </style>
</head>
<body>
  <h2 class="mb-20">Mehzmen-INVOICE</h2>

  <div class="row mb-10">
    <div>
      <div><strong>Order ID:</strong> <%= order.orderId %></div>
      <div><strong>Placed On:</strong> <%= new Date(order.createdAt).toLocaleString() %></div>
      <div><strong>Invoice Date:</strong> <%= new Date(order.invoiceDate || new Date()).toLocaleString() %></div>
    </div>
    <div>
      <div><strong>Payment Method:</strong> <%= String(order.paymentMethod || '').toUpperCase() %></div>
      <div><strong>Payment Status:</strong> <%= order.paymentStatus %></div>
      <div><strong>Order Status:</strong> <%= order.orderStatus %></div>
    </div>
  </div>

  <div class="mb-20">
    <h3 class="mb-10">Shipping Address</h3>
    <div><%= order.shippingAddress.name %> - <%= order.shippingAddress.phone %></div>
    <div>
      <%= order.shippingAddress.houseNo %>, <%= order.shippingAddress.landMark %>,
      <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> -
      <%= order.shippingAddress.pincode %>, <%= order.shippingAddress.country %>
    </div>
  </div>

  <h3>Items</h3>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Product</th>
        <th>Brand</th>
        <th>Color</th>
        <th>Size</th>
        <th>Qty</th>
        <th>Price</th>
        <th>Total</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% order.items.forEach((item, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= item.productName %></td>
          <td><%= item.brand || 'N/A' %></td>
          <td><%= item.color || '-' %></td>
          <td><%= item.size || '-' %></td>
          <td><%= item.quantity %></td>
          <td>₹<%= item.price %></td>
          <td>₹<%= item.itemTotal %></td>
          <td><%= item.itemStatus %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div style="margin-top: 20px; width: 280px; margin-left: auto;">
    <div class="row mb-10"><span>Subtotal:</span><span>₹<%= order.pricing.subtotal %></span></div>
    <div class="row mb-10"><span>Shipping:</span><span>₹<%= order.pricing.shippingCharge %></span></div>
    <div class="row mb-10"><span>Discount:</span><span>₹<%= order.pricing.couponDiscount || 0 %></span></div>
    <div class="row"><strong>Grand Total:</strong><strong>₹<%= order.pricing.finalAmount %></strong></div>
  </div>
</body>
</html>