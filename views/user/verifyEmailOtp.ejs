<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Email OTP</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

  <style>
    body { background: #f6f7fb; padding-top: 60px; }
    .card-soft {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      border: 1px solid #eee;
    }
    .otp-input {
      height: 48px;
      border-radius: 10px;
      text-align: center;
      letter-spacing: 1px;
    }
    .otp-btn {
      background: #167a3f;
      border: none;
      height: 48px;
      border-radius: 10px;
      font-weight: 600;
    }
    .otp-btn:hover {
      background: #136b36;
    }
    .helper-text {
      color: #6c757d;
      font-size: 0.9rem;
    }
    .error-text { color: #dc3545; font-size: 0.875rem; }
  </style>
</head>
<body>
  <%- include("../partials/user/header") %>

  <%
    const emailText = pendingEmail ? pendingEmail : 'your email';
  %>

  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card card-soft p-4 text-center">
          <h4 class="mb-2">Verify Your Email</h4>
          <p class="text-muted mb-4">We sent a 6-digit verification code to <strong><%= emailText %></strong>.<br>Please enter the OTP below to verify your new email address.</p>

          <form action="/verify-email-otp" method="POST" id="verifyOtpForm" onsubmit="return gatherOTP()">
            <div class="mb-3 text-start">
              <label class="form-label">Enter OTP</label>
              <input type="text" name="otp" id="otp" class="form-control otp-input" placeholder="Enter 6-digit code">
              <div class="error-text" id="otpError"></div>
            </div>

            <button type="submit" class="btn btn-success w-100 otp-btn">Verify Email</button>
          </form>

          <div class="mt-3 text-center helper-text" id="timer">Resend OTP after 60s</div>
          <div class="mt-2 text-center">
            <button type="button" class="btn btn-link text-muted text-decoration-none p-0" id="resendBtn" onclick="return resendOTP()" style="display: none;">Resend OTP</button>
            <span class="text-muted mx-2">|</span>
            <a href="/userProfile" class="text-muted text-decoration-none">Cancel</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/user/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let otpInput = document.getElementById('otp');
    let timer = document.getElementById('timer');
    let resendLink = document.getElementById('resendBtn');
    let interval;
    let seconds = 60;

    function gatherOTP() {
      const otpValue = otpInput.value.trim();
      const otpError = document.getElementById('otpError');
      otpError.textContent = '';

      if (!otpValue) {
        otpError.textContent = 'OTP is required';
        return false;
      }

      if (!/^[0-9]{6}$/.test(otpValue)) {
        otpError.textContent = 'OTP must be 6 digits';
        return false;
      }

      $.ajax({
        type: 'POST',
        url: '/verify-email-otp',
        data: { otp: otpValue },
        success: function (response) {
          if (response.success) {
            Swal.fire({
              icon: 'success',
              title: 'OTP Verified successfully',
              showConfirmButton: false,
              timer: 1500
            }).then(() => {
              window.location.href = response.redirectUrl;
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: response.message || 'Invalid OTP'
            });
          }
        },
        error: function () {
          Swal.fire({
            icon: 'error',
            title: 'Invalid OTP',
            text: 'Please try again'
          });
        }
      });
      return false;
    }

    function resendOTP() {
      clearInterval(interval);
      seconds = 60;

      resendLink.disabled = true;
      resendLink.style.opacity = 0.5;

      $.ajax({
        type: 'POST',
        url: '/resend-change-Email-otp',
        success: function (response) {
          if (response.success) {
            Swal.fire({
              icon: 'success',
              title: 'OTP Resent successfully',
              showConfirmButton: false,
              timer: 1500
            });
            otpInput.value = '';
            otpInput.disabled = false;

            resendLink.disabled = false;
            resendLink.style.opacity = '1';

            startTimer();
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: response.message || 'Error while resending OTP'
            });
          }
        },
        error: function () {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'Internal Server Error'
          });
          resendLink.disabled = false;
          resendLink.style.opacity = '1';
        }
      });
      return false;
    }

    function startTimer() {
      clearInterval(interval);
      seconds = 60;
      timer.style.display = 'inline';
      resendLink.style.display = 'none';
      interval = setInterval(() => {
        seconds--;
        timer.textContent = `Resend OTP after ${seconds}s`;

        if (seconds <= 0) {
          clearInterval(interval);
          timer.style.display = 'none';
          resendLink.style.display = 'inline';
        }
      }, 1000);
    }

    window.onload = startTimer;
  </script>
</body>
</html>

