<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/user/home.css">
</head>

<body>
  <%- include("../partials/user/header") %>
    <!-- Hero Banner Slider (Static) -->
    <div id="heroCarousel" class="carousel slide card-soft overflow-hidden" data-bs-ride="carousel"
      data-bs-interval="3500">
      <div class="carousel-inner">
        <div class="carousel-item active">
          <img src="/images/banner-1.jpg" class="banner-img" alt="Banner 1">
          <div class="carousel-caption d-none d-md-block text-start">
            <h3>New Season Arrivals</h3>
            <p>Premium men’s fashion</p>
            <a href="/allProducts" class="btn btn-dark">Shop Now</a>
          </div>
        </div>

        <div class="carousel-item">
          <img src="/images/banner-2.jpg" class="banner-img" alt="Banner 2">
          <div class="carousel-caption d-none d-md-block text-start">
            <h3>Casual Essentials</h3>
            <p>Everyday comfort</p>
            <a href="/allProducts" class="btn btn-dark">Explore</a>
          </div>
        </div>

        <div class="carousel-item">
          <img src="/images/banner-3.jpg" class="banner-img" alt="Banner 3">
          <div class="carousel-caption d-none d-md-block text-start">
            <h3>Formal Collection</h3>
            <p>Sharp & classy</p>
            <a href="/allProducts" class="btn btn-dark">View Now</a>
          </div>
        </div>
      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
    <main class="container py-4">

      <!-- New Arrivals -->
      <div class="mt-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="section-title">New Arrivals</h4>
          <div class="d-flex gap-2">
            <button class="scroll-btn" type="button" data-dir="left" data-target="newArrivalsTrack">
              <i class="bi bi-chevron-left"></i>
            </button>
            <button class="scroll-btn" type="button" data-dir="right" data-target="newArrivalsTrack">
              <i class="bi bi-chevron-right"></i>
            </button>
          </div>
        </div>
        <div class="scroll-wrapper">
          <div id="newArrivalsTrack" class="scroll-track">
            <% if (newArrivals && newArrivals.length) { %>
              <% newArrivals.forEach(item=> { %>
                <div class="arrival-card card-soft p-3">
                  <a href="/productDetails/<%= item._id %>" class="text-decoration-none text-dark">
                    <img src="<%= item.image %>" class="w-100" alt="<%= item.name %>">
                    <h6 class="mt-3 mb-1">
                      <%= item.name %>
                    </h6>
                    <small class="text-muted">Brand: <%= item.brandName %></small>
                    <div class="mt-2 fw-bold">₹<%= item.price %>
                    </div>
                  </a>
                </div>
                <% }) %>
                  <% } else { %>
                    <p class="text-muted">No new arrivals found.</p>
                    <% } %>
          </div>
        </div>
      </div>

      <!-- Shop by Category -->
      <div class="mt-5">
        <h4 class="section-title">Shop by Category</h4>
        <div class="row g-4">
          <% if (categories && categories.length) { %>
            <% categories.forEach(cat=> { %>
              <div class="col-12 col-md-6 col-lg-4">
                <a href="/allProducts?category=<%= cat._id %>" class="text-decoration-none text-dark">
                  <div class="card-soft p-3">
                    <img src="<%= cat.image %>" class="w-100 category-card" alt="<%= cat.name %>">
                    <h6 class="mt-3 mb-0">
                      <%= cat.name %>
                    </h6>
                    <small class="text-muted">Explore</small>
                  </div>
                </a>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="text-muted">No categories found.</p>
                  <% } %>
        </div>
      </div>

      <!-- Top Brands -->
      <div class="mt-5">
        <h4 class="section-title">Top Brands</h4>
        <div class="row g-3">
          <% if (brands && brands.length) { %>
            <% brands.forEach(br=> { %>
              <div class="col-6 col-md-3">
                <a href="/allProducts?brand=<%= br._id %>" class="d-flex justify-content-center card-soft p-3">
                  <img src="<%= br.logo || br.image || '/images/brand-placeholder.png' %>" class="brand-logo"
                    alt="<%= br.name %>">
                </a>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="text-muted">No brands found.</p>
                  <% } %>
        </div>
      </div>
    </main>

    <%- include("../partials/user/footer") %>

      
      <script>
        // Simple horizontal slider for New Arrivals
        document.querySelectorAll('.scroll-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const targetId = btn.dataset.target;
            const dir = btn.dataset.dir;
            const track = document.getElementById(targetId);
            if (!track) return;

            const scrollAmount = track.clientWidth * 0.8;
            track.scrollBy({ left: dir === 'left' ? -scrollAmount : scrollAmount, behavior: 'smooth' });
          });
        });
      </script>

</body>
</html>