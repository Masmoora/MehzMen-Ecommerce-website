<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Change Password</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background: #f5f6fa;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .change-password-card {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      max-width: 900px;
      width: 100%;
    }

    .form-section {
      padding: 60px 50px;
    }

    .form-section h3 {
      font-weight: 700;
      margin-bottom: 30px;
    }

    .form-control {
      border-radius: 8px;
      padding: 12px 15px;
      font-size: 14px;
    }

    .btn-dark {
      border-radius: 8px;
      padding: 12px;
      font-weight: 600;
    }

    .back-link {
      display: block;
      margin-top: 15px;
      font-size: 14px;
      color: #6c757d;
      text-decoration: none;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .image-section {
      background-image: url('/images/change-password.jpg');
      background-size: cover;
      background-position: center;
      min-height: 100%;
    }
            .right-section {
            flex: 1;
            background: #ddd;
            overflow: hidden;
        }

        .right-section img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    @media (max-width: 768px) {
      .image-section {
        display: none;
      }
    }
  </style>
</head>

<body>
  <div class="change-password-card row g-0">
    
    <!-- Left Form Section -->
    <div class="col-md-6 form-section">
      <h3>Change Password</h3>

      <form action="/reset-password" method="POST">
        <div class="mb-3">
          <input
            type="password"
            name="password"
            class="form-control"
            placeholder="New password"
            required
          />
        </div>

        <div class="mb-4">
          <input
            type="password"
            name="confirmPassword"
            class="form-control"
            placeholder="Confirm Password"
            required
          />
        </div>

        <button type="submit" class="btn btn-dark w-100">
          Change Password
        </button>
      </form>

      <a href="/login" class="back-link">Go back to Login page</a>
    </div>

    <!-- Right Image Section -->
    <div class="col-md-6 image-section right-section">
        <img src="/images/resetpassword.webp" alt="Fashion Image">
    </div>
  </div>
</body>
</html>

