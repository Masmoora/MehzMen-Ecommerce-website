<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Change Password</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/user/resetPassword.css">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>

  </style>
</head>

<body>
  <div class="change-password-card row g-0">

    <!-- Left Form Section -->
    <div class="col-md-6 form-section">
      <h3>Change Password</h3>

      <form action="/reset-password" method="POST">
        <div class="mb-3">
          <input type="password" name="password" class="form-control" placeholder="New password" required />
        </div>

        <div class="mb-4">
          <input type="password" name="confirmPassword" class="form-control" placeholder="Confirm Password" required />
        </div>

        <button type="submit" class="btn btn-dark w-100">
          Change Password
        </button>
      </form>

      <a href="/login" class="back-link">Go back to Login page</a>
    </div>

    <!-- Right Image Section -->
    <div class="col-md-6 image-section right-section">
      <img src="/images/resetpassword.webp" alt="Fashion Image">
    </div>
  </div>
</body>

</html>