<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Wallet</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    body {
      background: #f6f7fb;
      padding-top: 52px;
    }
    .card-soft {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
    }
    .wallet-balance-card {
      background: linear-gradient(135deg, #00b4db 0%, #0083b0 100%);
      border-radius: 16px;
      color: #fff;
      padding: 1.75rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    }
    .wallet-balance-label {
      font-size: 0.95rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.9;
    }
    .wallet-balance-value {
      font-size: 2.4rem;
      font-weight: 700;
      margin-top: 0.25rem;
    }
    .wallet-add-btn {
      min-width: 160px;
    }
    .tx-card {
      border-left: 4px solid transparent;
      border-radius: 10px;
      padding: 0.75rem 1rem;
      margin-bottom: 0.5rem;
    }
    .tx-credit {
      border-color: #16a34a;
      background: #ecfdf3;
    }
    .tx-debit {
      border-color: #dc2626;
      background: #fef2f2;
    }
    .tx-amount {
      font-weight: 600;
    }
  </style>
</head>
<body>
  <%- include("../partials/user/header") %>

  <main class="container pt-2 pb-4">
    <div class="row">
      <div class="col-lg-3 mb-3">
        <%- include("../partials/user/profileSidebar", { user, activeItem: "wallet" }) %>
      </div>

      <div class="col-lg-9">
        <h4 class="mb-3">My Wallet</h4>

        <div class="card-soft p-4 mb-4">
          <div class="row g-3 align-items-center">
            <div class="col-md-8">
              <div class="wallet-balance-card">
                <span class="wallet-balance-label">Available Balance</span>
                <div class="wallet-balance-value">₹<%= Number(balance || 0).toFixed(2) %></div>
              </div>
            </div>
            <div class="col-md-4 d-flex flex-column align-items-md-end align-items-start gap-2">
              <button type="button" class="btn btn-primary wallet-add-btn" disabled>
                + Add to Wallet
              </button>
              <small class="text-muted d-block">
                Refunds from cancelled and returned orders are credited here.
              </small>
            </div>
          </div>
        </div>

        <div class="card-soft p-4">
          <h5 class="mb-3">Transaction History</h5>
          <% if (!transactions || !transactions.length) { %>
            <p class="text-muted mb-0">No wallet transactions yet.</p>
          <% } else { %>
            <div class="list-group">
              <% transactions.forEach(function(tx) { %>
                <div class="tx-card <%= tx.type === 'credit' ? 'tx-credit' : 'tx-debit' %>">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <div class="fw-semibold mb-1">
                        <%= tx.type === 'credit' ? 'Credited' : 'Debited' %>
                      </div>
                      <div class="small text-muted mb-1">
                        <%= tx.reason || (tx.type === 'credit' ? 'Refund' : 'Wallet payment') %>
                      </div>
                      <div class="small text-muted">
                        <%= new Date(tx.createdAt).toLocaleString() %>
                        <% if (tx.orderId) { %>
                          · Order: <%= tx.orderId %>
                        <% } %>
                      </div>
                    </div>
                    <div class="text-end tx-amount <%= tx.type === 'credit' ? 'text-success' : 'text-danger' %>">
                      <%= tx.type === 'credit' ? '+' : '-' %> ₹<%= Number(tx.amount || 0).toFixed(2) %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/user/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>